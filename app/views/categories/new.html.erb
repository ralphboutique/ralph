<!-- Header Section -->
<div class="bg-white border-b border-gray-200">
    <div class="px-4 sm:px-6 lg:px-8 py-6">
        <div class="flex items-center justify-between">
            <div class="flex items-center space-x-3">
                <div class="flex items-center justify-center w-10 h-10 bg-purple-100 rounded-lg">
                    <i class="fas fa-tags text-purple-600 text-lg"></i>
                </div>
                <div>
                    <h1 class="text-2xl font-bold text-gray-900">Nueva Categoría</h1>
                    <p class="text-sm text-gray-500 mt-1">Crea una nueva categoría para organizar tus productos</p>
                </div>
            </div>
            <%= link_to show_category_path, 
                class: "inline-flex items-center px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 hover:text-gray-900 transition-colors duration-200" do %>
                <i class="fas fa-arrow-left mr-2"></i>
                Volver
            <% end %>
        </div>
    </div>
</div>

<!-- Main Content -->
<div class="px-4 sm:px-6 lg:px-8 py-8">
    <%= form_for @category, url: create_category_path, local: true do |f| %>
        <!-- Error Messages -->
        <% if @category.errors.any? %>
            <div class="mb-6 bg-red-50 border border-red-200 rounded-lg p-4">
                <div class="flex items-start">
                    <i class="fas fa-exclamation-triangle text-red-400 text-lg mt-0.5 mr-3"></i>
                    <div class="flex-1">
                        <h3 class="text-sm font-medium text-red-800">
                            <%= pluralize(@category.errors.count, "error") %> impidieron que la categoría se guardara:
                        </h3>
                        <ul class="mt-2 text-sm text-red-700 list-disc list-inside">
                            <% @category.errors.full_messages.each do |message| %>
                                <li><%= message %></li>
                            <% end %>
                        </ul>
                    </div>
                </div>
            </div>
        <% end %>

        <div class="max-w-2xl mx-auto">
            <!-- Main Form Card -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8">
                <div class="flex items-center space-x-3 mb-8">
                    <div class="flex items-center justify-center w-8 h-8 bg-purple-100 rounded-lg">
                        <i class="fas fa-info-circle text-purple-600"></i>
                    </div>
                    <h2 class="text-xl font-semibold text-gray-900">Información de la Categoría</h2>
                </div>
                
                <div class="space-y-6">
                    <!-- Category Name -->
                    <div>
                        <%= f.label :title, "Nombre de la Categoría", class: "block text-sm font-medium text-gray-700 mb-2" %>
                        <%= f.text_field :title, 
                            class: "block w-full px-4 py-3 bg-white border border-gray-300 rounded-lg text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-colors duration-200",
                            placeholder: "Ej: ROPA DEPORTIVA, CALZADO, ACCESORIOS...",
                            oninput: "this.value = this.value.toUpperCase()" %>
                        <p class="mt-2 text-sm text-gray-500">
                            <i class="fas fa-lightbulb mr-1"></i>
                            El nombre se convertirá automáticamente a mayúsculas
                        </p>
                    </div>

                    <!-- Description Section -->
                    <div class="bg-gray-50 rounded-lg p-4">
                        <h4 class="text-sm font-medium text-gray-700 mb-3 flex items-center">
                            <i class="fas fa-info-circle mr-2 text-gray-500"></i>
                            Información sobre Categorías
                        </h4>
                        <ul class="text-sm text-gray-600 space-y-2">
                            <li class="flex items-start">
                                <i class="fas fa-check text-green-500 mt-0.5 mr-2 text-xs"></i>
                                Las categorías ayudan a organizar y filtrar productos
                            </li>
                            <li class="flex items-start">
                                <i class="fas fa-check text-green-500 mt-0.5 mr-2 text-xs"></i>
                                Pueden editarse o eliminarse después de crearlas
                            </li>
                            <li class="flex items-start">
                                <i class="fas fa-check text-green-500 mt-0.5 mr-2 text-xs"></i>
                                Los productos pueden cambiar de categoría en cualquier momento
                            </li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="mt-8 flex items-center justify-end space-x-4">
                <%= link_to show_category_path, 
                    class: "inline-flex items-center px-6 py-3 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 hover:text-gray-900 transition-colors duration-200" do %>
                    <i class="fas fa-times mr-2"></i>
                    Cancelar
                <% end %>
                <%= f.submit "Crear Categoría", 
                    class: "inline-flex items-center px-6 py-3 text-sm font-medium text-white bg-purple-600 border border-transparent rounded-lg hover:bg-purple-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500 transition-colors duration-200" %>
            </div>
        </div>
    <% end %>
</div>

<!-- JavaScript for enhanced UX -->
<script>
document.addEventListener('DOMContentLoaded', function() {
    const titleInput = document.querySelector('input[name="category[title]"]');
    
    if (titleInput) {
        titleInput.addEventListener('input', function() {
            // Add visual feedback for valid input
            if (this.value.length >= 3) {
                this.classList.remove('border-red-300');
                this.classList.add('border-green-300');
            } else {
                this.classList.remove('border-green-300');
                this.classList.add('border-gray-300');
            }
        });
    }
});
</script>