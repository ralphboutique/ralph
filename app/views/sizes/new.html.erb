<!-- Header Section -->
<div class="bg-white border-b border-gray-200">
    <div class="px-4 sm:px-6 lg:px-8 py-6">
        <div class="flex items-center justify-between">
            <div class="flex items-center space-x-3">
                <div class="flex items-center justify-center w-10 h-10 bg-indigo-100 rounded-lg">
                    <i class="fas fa-ruler text-indigo-600 text-lg"></i>
                </div>
                <div>
                    <h1 class="text-2xl font-bold text-gray-900">Nueva Talla</h1>
                    <p class="text-sm text-gray-500 mt-1">Crea una nueva talla para clasificar tus productos</p>
                </div>
            </div>
            <%= link_to show_size_path, 
                class: "inline-flex items-center px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 hover:text-gray-900 transition-colors duration-200" do %>
                <i class="fas fa-arrow-left mr-2"></i>
                Volver
            <% end %>
        </div>
    </div>
</div>

<!-- Main Content -->
<div class="px-4 sm:px-6 lg:px-8 py-8">
    <%= form_for @size, url: create_size_path, local: true do |f| %>
        <!-- Error Messages -->
        <% if @size.errors.any? %>
            <div class="mb-6 bg-red-50 border border-red-200 rounded-lg p-4">
                <div class="flex items-start">
                    <i class="fas fa-exclamation-triangle text-red-400 text-lg mt-0.5 mr-3"></i>
                    <div class="flex-1">
                        <h3 class="text-sm font-medium text-red-800">
                            <%= pluralize(@size.errors.count, "error") %> impidieron que la talla se guardara:
                        </h3>
                        <ul class="mt-2 text-sm text-red-700 list-disc list-inside">
                            <% @size.errors.full_messages.each do |message| %>
                                <li><%= message %></li>
                            <% end %>
                        </ul>
                    </div>
                </div>
            </div>
        <% end %>

        <div class="max-w-2xl mx-auto">
            <!-- Main Form Card -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8">
                <div class="flex items-center space-x-3 mb-8">
                    <div class="flex items-center justify-center w-8 h-8 bg-indigo-100 rounded-lg">
                        <i class="fas fa-info-circle text-indigo-600"></i>
                    </div>
                    <h2 class="text-xl font-semibold text-gray-900">Información de la Talla</h2>
                </div>
                
                <div class="space-y-6">
                    <!-- Size Name -->
                    <div>
                        <%= f.label :title, "Nombre de la Talla", class: "block text-sm font-medium text-gray-700 mb-2" %>
                        <%= f.text_field :title, 
                            class: "block w-full px-4 py-3 bg-white border border-gray-300 rounded-lg text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-colors duration-200",
                            placeholder: "Ej: S, M, L, XL, 32, 34, 36...",
                            oninput: "this.value = this.value.toUpperCase()" %>
                        <p class="mt-2 text-sm text-gray-500">
                            <i class="fas fa-lightbulb mr-1"></i>
                            El nombre se convertirá automáticamente a mayúsculas
                        </p>
                    </div>

                    <!-- Size Types Section -->
                    <div class="bg-gray-50 rounded-lg p-4">
                        <h4 class="text-sm font-medium text-gray-700 mb-3 flex items-center">
                            <i class="fas fa-list mr-2 text-gray-500"></i>
                            Tipos de Tallas Comunes
                        </h4>
                        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
                            <div class="text-center p-3 bg-white rounded-lg border">
                                <i class="fas fa-tshirt text-indigo-500 text-lg mb-2"></i>
                                <p class="text-xs font-medium text-gray-700">Ropa</p>
                                <p class="text-xs text-gray-500">XS, S, M, L, XL</p>
                            </div>
                            <div class="text-center p-3 bg-white rounded-lg border">
                                <i class="fas fa-shoe-prints text-indigo-500 text-lg mb-2"></i>
                                <p class="text-xs font-medium text-gray-700">Calzado</p>
                                <p class="text-xs text-gray-500">35, 36, 37, 38</p>
                            </div>
                            <div class="text-center p-3 bg-white rounded-lg border">
                                <i class="fas fa-ring text-indigo-500 text-lg mb-2"></i>
                                <p class="text-xs font-medium text-gray-700">Accesorios</p>
                                <p class="text-xs text-gray-500">ÚNICO, CHICO</p>
                            </div>
                        </div>
                    </div>

                    <!-- Guidelines -->
                    <div class="bg-blue-50 rounded-lg p-4 border border-blue-200">
                        <h4 class="text-sm font-medium text-blue-800 mb-3 flex items-center">
                            <i class="fas fa-lightbulb mr-2"></i>
                            Recomendaciones
                        </h4>
                        <ul class="text-sm text-blue-700 space-y-1">
                            <li>• Mantén consistencia en el sistema de tallas</li>
                            <li>• Usa abreviaciones estándar cuando sea posible</li>
                            <li>• Considera tallas especiales si es necesario</li>
                            <li>• Ordena las tallas de menor a mayor</li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="mt-8 flex items-center justify-end space-x-4">
                <%= link_to show_size_path, 
                    class: "inline-flex items-center px-6 py-3 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 hover:text-gray-900 transition-colors duration-200" do %>
                    <i class="fas fa-times mr-2"></i>
                    Cancelar
                <% end %>
                <%= f.submit "Crear Talla", 
                    class: "inline-flex items-center px-6 py-3 text-sm font-medium text-white bg-indigo-600 border border-transparent rounded-lg hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors duration-200" %>
            </div>
        </div>
    <% end %>
</div>

<!-- JavaScript for enhanced UX -->
<script>
document.addEventListener('DOMContentLoaded', function() {
    const titleInput = document.querySelector('input[name="size[title]"]');
    
    if (titleInput) {
        titleInput.addEventListener('input', function() {
            // Add visual feedback for valid input
            if (this.value.length >= 1) {
                this.classList.remove('border-red-300');
                this.classList.add('border-green-300');
            } else {
                this.classList.remove('border-green-300');
                this.classList.add('border-gray-300');
            }
        });

        // Quick size suggestions
        const sizeButtons = [
            'XS', 'S', 'M', 'L', 'XL', 'XXL',
            '32', '34', '36', '38', '40', '42',
            'ÚNICO'
        ];

        titleInput.addEventListener('focus', function() {
            if (!this.value) {
                this.placeholder = "Haz clic en los ejemplos de arriba o escribe tu talla";
            }
        });
    }
});
</script>

