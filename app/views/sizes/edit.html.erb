<!-- Header Section -->
<div class="bg-white border-b border-gray-200">
    <div class="px-4 sm:px-6 lg:px-8 py-6">
        <div class="flex items-center justify-between">
            <div class="flex items-center space-x-3">
                <div class="flex items-center justify-center w-10 h-10 bg-orange-100 rounded-lg">
                    <i class="fas fa-edit text-orange-600 text-lg"></i>
                </div>
                <div>
                    <h1 class="text-2xl font-bold text-gray-900">Editar Talla</h1>
                    <p class="text-sm text-gray-500 mt-1">Modifica la información de: <span class="font-medium text-gray-700"><%= @size.title %></span></p>
                </div>
            </div>
            <%= link_to show_size_path, 
                class: "inline-flex items-center px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 hover:text-gray-900 transition-colors duration-200" do %>
                <i class="fas fa-arrow-left mr-2"></i>
                Volver
            <% end %>
        </div>
    </div>
</div>

<!-- Main Content -->
<div class="px-4 sm:px-6 lg:px-8 py-8">
    <%= form_for @size, url: update_size_path(@size), method: :patch, local: true do |f| %>
        <!-- Error Messages -->
        <% if @size.errors.any? %>
            <div class="mb-6 bg-red-50 border border-red-200 rounded-lg p-4">
                <div class="flex items-start">
                    <i class="fas fa-exclamation-triangle text-red-400 text-lg mt-0.5 mr-3"></i>
                    <div class="flex-1">
                        <h3 class="text-sm font-medium text-red-800">
                            <%= pluralize(@size.errors.count, "error") %> impidieron que la talla se actualizara:
                        </h3>
                        <ul class="mt-2 text-sm text-red-700 list-disc list-inside">
                            <% @size.errors.full_messages.each do |message| %>
                                <li><%= message %></li>
                            <% end %>
                        </ul>
                    </div>
                </div>
            </div>
        <% end %>

        <div class="max-w-4xl mx-auto">
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                <!-- Main Form Card -->
                <div class="lg:col-span-2">
                    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8">
                        <div class="flex items-center space-x-3 mb-8">
                            <div class="flex items-center justify-center w-8 h-8 bg-orange-100 rounded-lg">
                                <i class="fas fa-info-circle text-orange-600"></i>
                            </div>
                            <h2 class="text-xl font-semibold text-gray-900">Información de la Talla</h2>
                        </div>
                        
                        <div class="space-y-6">
                            <!-- Size Name -->
                            <div>
                                <%= f.label :title, "Nombre de la Talla", class: "block text-sm font-medium text-gray-700 mb-2" %>
                                <%= f.text_field :title, 
                                    class: "block w-full px-4 py-3 bg-white border border-gray-300 rounded-lg text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition-colors duration-200",
                                    oninput: "this.value = this.value.toUpperCase()" %>
                                <p class="mt-2 text-sm text-gray-500">
                                    <i class="fas fa-lightbulb mr-1"></i>
                                    El nombre se convertirá automáticamente a mayúsculas
                                </p>
                            </div>

                            <!-- Change History -->
                            <div class="bg-amber-50 rounded-lg p-4 border border-amber-200">
                                <h4 class="text-sm font-medium text-amber-800 mb-3 flex items-center">
                                    <i class="fas fa-history mr-2"></i>
                                    Historial de Cambios
                                </h4>
                                <div class="text-sm text-amber-700 space-y-1">
                                    <p>• <strong>Creada:</strong> <%= @size.created_at.strftime("%d/%m/%Y a las %H:%M") %></p>
                                    <% if @size.updated_at != @size.created_at %>
                                        <p>• <strong>Última modificación:</strong> <%= @size.updated_at.strftime("%d/%m/%Y a las %H:%M") %></p>
                                    <% end %>
                                </div>
                            </div>

                            <!-- Size Usage Info -->
                            <div class="bg-yellow-50 rounded-lg p-4 border border-yellow-200">
                                <h4 class="text-sm font-medium text-yellow-800 mb-2 flex items-center">
                                    <i class="fas fa-exclamation-triangle mr-2"></i>
                                    Impacto de los Cambios
                                </h4>
                                <p class="text-sm text-yellow-700">
                                    Modificar el nombre de la talla actualizará automáticamente todos los productos que la tengan asignada.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Information Sidebar -->
                <div class="lg:col-span-1">
                    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
                        <div class="flex items-center space-x-3 mb-6">
                            <div class="flex items-center justify-center w-8 h-8 bg-blue-100 rounded-lg">
                                <i class="fas fa-chart-bar text-blue-600"></i>
                            </div>
                            <h3 class="text-lg font-semibold text-gray-900">Estadísticas</h3>
                        </div>

                        <!-- Size Stats -->
                        <div class="space-y-4">
                            <div class="bg-gray-50 rounded-lg p-4">
                                <div class="flex items-center justify-between">
                                    <span class="text-sm font-medium text-gray-600">Productos</span>
                                    <span class="text-lg font-bold text-gray-900">
                                        <%= @size.article_sizes.count rescue 0 %>
                                    </span>
                                </div>
                                <p class="text-xs text-gray-500 mt-1">Productos con esta talla</p>
                            </div>

                            <div class="bg-gray-50 rounded-lg p-4">
                                <div class="flex items-center justify-between">
                                    <span class="text-sm font-medium text-gray-600">Uso</span>
                                    <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                        <i class="fas fa-circle text-green-400 mr-1"></i>
                                        Activa
                                    </span>
                                </div>
                                <p class="text-xs text-gray-500 mt-1">La talla está disponible</p>
                            </div>
                        </div>

                        <!-- Size Guide -->
                        <div class="mt-6 p-4 bg-blue-50 rounded-lg border border-blue-200">
                            <h4 class="text-sm font-medium text-blue-800 mb-3 flex items-center">
                                <i class="fas fa-ruler mr-2"></i>
                                Guía de Tallas
                            </h4>
                            <div class="text-xs text-blue-700 space-y-2">
                                <div class="flex justify-between">
                                    <span>Ropa:</span>
                                    <span>XS → XXL</span>
                                </div>
                                <div class="flex justify-between">
                                    <span>Calzado:</span>
                                    <span>35 → 45</span>
                                </div>
                                <div class="flex justify-between">
                                    <span>Accesorios:</span>
                                    <span>ÚNICO</span>
                                </div>
                            </div>
                        </div>

                        <!-- Related Sizes -->
                        <div class="mt-4 p-4 bg-gray-50 rounded-lg">
                            <h4 class="text-sm font-medium text-gray-700 mb-3 flex items-center">
                                <i class="fas fa-tags mr-2"></i>
                                Tallas Relacionadas
                            </h4>
                            <div class="flex flex-wrap gap-1">
                                <% Size.where.not(id: @size.id).limit(6).each do |related_size| %>
                                    <span class="inline-flex items-center px-2 py-1 rounded text-xs font-medium bg-white text-gray-700 border">
                                        <%= related_size.title %>
                                    </span>
                                <% end %>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="mt-8 flex items-center justify-end space-x-4">
                <%= link_to show_size_path, 
                    class: "inline-flex items-center px-6 py-3 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 hover:text-gray-900 transition-colors duration-200" do %>
                    <i class="fas fa-times mr-2"></i>
                    Cancelar
                <% end %>
                <%= f.submit "Actualizar Talla", 
                    class: "inline-flex items-center px-6 py-3 text-sm font-medium text-white bg-orange-600 border border-transparent rounded-lg hover:bg-orange-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-orange-500 transition-colors duration-200" %>
            </div>
        </div>
    <% end %>
</div>

<!-- JavaScript for enhanced UX -->
<script>
document.addEventListener('DOMContentLoaded', function() {
    const titleInput = document.querySelector('input[name="size[title]"]');
    
    if (titleInput) {
        // Store original value
        const originalValue = titleInput.value;
        
        titleInput.addEventListener('input', function() {
            // Add visual feedback for changes
            if (this.value !== originalValue) {
                this.classList.add('border-orange-300', 'bg-orange-50');
            } else {
                this.classList.remove('border-orange-300', 'bg-orange-50');
            }
        });
    }
});
</script>