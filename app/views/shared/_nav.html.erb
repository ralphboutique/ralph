<nav class="bg-gradient-to-r from-purple-900 to-black shadow-lg sticky top-0 z-40">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      
      <!-- Logo -->
      <div class="flex items-center">
        <%= link_to root_path, class: "flex items-center space-x-3" do %>
          <div class="bg-white rounded-full p-2">
            <svg class="w-8 h-8 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
            </svg>
          </div>
          <h1 class="text-2xl font-bold text-white tracking-wide">GG STORE</h1>
        <% end %>
      </div>

      <!-- Navigation Links (Desktop) -->
      <div class="hidden md:flex items-center space-x-8">
        <%= link_to root_path, class: "text-white hover:text-purple-300 transition-colors duration-200 font-medium" do %>
          Inicio
        <% end %>
        
        <%= link_to products_path, class: "text-white hover:text-purple-300 transition-colors duration-200 font-medium" do %>
          Productos
        <% end %>
        
        <%= link_to categories_path, class: "text-white hover:text-purple-300 transition-colors duration-200 font-medium" do %>
          Categorías
        <% end %>
      </div>

      <!-- Cart and User Actions -->
      <div class="flex items-center space-x-4">
        
        <!-- Cart Button -->
        <%= link_to cart_path, class: "relative p-2 text-white hover:text-blue-200 transition-colors duration-200" do %>
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4m0 0L7 13m0 0l-1.5 6M7 13l-1.5 6m0 0h9M17 21a1 1 0 100-2 1 1 0 000 2zm-8 0a1 1 0 100-2 1 1 0 000 2z"></path>
          </svg>
          
          <!-- Cart Counter -->
          <% 
            current_cart = nil
            begin
              if user_signed_in?
                current_cart = current_user.carts.active.first_or_create!(
                  session_id: session.id.to_s,
                  status: 'active'
                )
              else
                current_cart = Cart.for_session(session.id.to_s).active.first_or_create!(
                  session_id: session.id.to_s,
                  status: 'active'
                )
              end
            rescue
              # En caso de error, mostrar 0
            end
            
            cart_count = current_cart&.total_items || 0
          %>
          
          <% if cart_count > 0 %>
            <span class="cart-counter absolute -top-2 -right-2 bg-red-500 text-white text-xs rounded-full h-5 w-5 flex items-center justify-center font-bold">
              <%= cart_count %>
            </span>
          <% else %>
            <span class="cart-counter absolute -top-2 -right-2 bg-red-500 text-white text-xs rounded-full h-5 w-5 flex items-center justify-center font-bold hidden">
              0
            </span>
          <% end %>
        <% end %>

        <!-- User Menu -->
        <% if user_signed_in? %>
          <div class="relative group">
            <button class="flex items-center space-x-2 text-white hover:text-blue-200 transition-colors duration-200">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
              </svg>
              <span class="hidden sm:block"><%= current_user.username %></span>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>
            
            <!-- Dropdown Menu -->
            <div class="absolute right-0 mt-2 w-48 bg-white rounded-lg shadow-lg py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform translate-y-1 group-hover:translate-y-0">
              <%= link_to "/admin", class: "block px-4 py-2 text-gray-800 hover:bg-blue-50 transition-colors duration-200" do %>
                <svg class="w-4 h-4 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                Administración
              <% end %>
              
              <hr class="my-2">
              
              <%= link_to destroy_user_session_path, method: :delete, class: "block px-4 py-2 text-red-600 hover:bg-red-50 transition-colors duration-200" do %>
                <svg class="w-4 h-4 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
                </svg>
                Cerrar sesión
              <% end %>
            </div>
          </div>
        <% else %>
          <%= link_to new_user_session_path, class: "bg-white text-blue-800 px-4 py-2 rounded-lg font-medium hover:bg-blue-50 transition-colors duration-200" do %>
            Iniciar sesión
          <% end %>
        <% end %>

        <!-- Mobile Menu Button -->
        <button class="md:hidden text-white hover:text-blue-200 transition-colors duration-200" id="mobile-menu-button">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div class="md:hidden hidden" id="mobile-menu">
      <div class="px-2 pt-2 pb-3 space-y-1 bg-blue-900">
        <%= link_to root_path, class: "block px-3 py-2 text-white hover:text-blue-200 hover:bg-blue-800 rounded-md transition-colors duration-200" do %>
          Inicio
        <% end %>
        
        <%= link_to products_path, class: "block px-3 py-2 text-white hover:text-blue-200 hover:bg-blue-800 rounded-md transition-colors duration-200" do %>
          Productos
        <% end %>
        
        <%= link_to categories_path, class: "block px-3 py-2 text-white hover:text-blue-200 hover:bg-blue-800 rounded-md transition-colors duration-200" do %>
          Categorías
        <% end %>
      </div>
    </div>
  </div>
</nav>

<script>
// Mobile menu toggle
document.addEventListener('DOMContentLoaded', function() {
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');
  
  if (mobileMenuButton && mobileMenu) {
    mobileMenuButton.addEventListener('click', function() {
      mobileMenu.classList.toggle('hidden');
    });
  }
});
</script> 