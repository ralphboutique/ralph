<!DOCTYPE html>
<html>
  <head>
    <title>RalphBoutique</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "inter-font", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "https://cdnjs.cloudflare.com/ajax/libs/select2/4.1.0-rc.0/css/select2.min.css", media: "all" %>
    <%= javascript_importmap_tags %>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="https://unpkg.com/flowbite@1.5.1/dist/flowbite.min.css" />
    <style>
    .scroller {
    scrollbar-color: #a0aec0 #141b2a;
    scrollbar-width: none !important;
}

/* width */
.scroller::-webkit-scrollbar {
    width: 6px;
    height: 6px;
}

/* Track */
.scroller::-webkit-scrollbar-track {
    border-radius: 100vh;
    background: #141b2a;
}

/* Handle */
.scroller::-webkit-scrollbar-thumb {
    background: #181818;
    border-radius: 100vh;
    border: 1px solid #181818;
}

/* Handle on hover */
.scroller::-webkit-scrollbar-thumb:hover {
    background: #a0aec0;
}

.scrollerlight {
    scrollbar-color: #cfcfcf #ffffff;
    scrollbar-width: none !important;
}

/* width */
.scrollerlight::-webkit-scrollbar {
    width: 2px;
    height: 6px;
}

/* Track */
.scrollerlight::-webkit-scrollbar-track {
    border-radius: 100vh;
    background: #ffffff;
}

/* Handle */
.scrollerlight::-webkit-scrollbar-thumb {
    background: #cecece;
    border-radius: 100vh;
    border: 1px solid #cecece;
}

/* Handle on hover */
.scrollerlight::-webkit-scrollbar-thumb:hover {
    background: #cecece;
}
</style>

  </head>
  <body>
        <div class="md:flex">

    <!-- Sidebar -->
    <div 
        class="sidebar max-h-screen top-0 h-screen bg-black text-blue-100 w-64 fixed inset-y-0 left-0 transform transition-transform duration-300 ease-in-out z-50 lg:relative lg:translate-x-0"
        x-data="{ open: false }" 
        x-on:togglesidebar.window="open = !open" 
        :class="open ? 'translate-x-0' : '-translate-x-full lg:translate-x-0'" 
        x-show="true">

        <!-- Header -->
        <header class="h-16 py-2 shadow-lg px-4 sticky top-0 bg-black z-40">
            <a href="#" class="flex items-center space-x-2 group text-white hover:text-white">
                <div>
                    <span class="text-lg lg:text-xl font-extrabold">RALPHBOUTIQUE</span>
                    <div class="text-xs text-gray-400">ADMIN</div>
                </div>
            </a>
        </header>
        
        <!-- User Info -->
        <div class="flex items-center p-4 text-white border-b border-gray-700">
            <div class="flex items-center justify-center w-10 h-10 bg-blue-600 rounded-full mr-3">
                <i class="fas fa-user text-white"></i>
            </div>
            <div class="flex-1 min-w-0">
                <div class="text-sm font-medium text-white truncate">
                    Bienvenido
                </div>
                <div class="text-xs text-gray-300 truncate">
                    <%= current_user.username %>
                </div>
            </div>
        </div>

        <!-- Navigation -->
        <nav class="px-4 pt-4 bg-black max-h-[calc(100vh-120px)] overflow-y-auto" x-data="{ selected: 'Tasks' }">
            <ul class="space-y-1">
                <!-- Item -->
                <li class="text-sm">
                    <%= link_to admin_path, class: "flex items-center px-3 py-2 text-gray-300 rounded-lg hover:bg-gray-800 hover:text-white transition-all duration-200" do %>
                        <i class="fas fa-home mr-3 w-4"></i>
                        <span>Inicio</span>
                    <% end %>
                </li>
                <% if has_permission?('Articulos', 'Ver') %>
                <!-- Section Divider -->
                <div class="section border-b pt-4 mb-4 text-xs text-gray-600 border-gray-700 pb-1 pl-3">
                    Artículos
                </div>

                <!-- Item -->
                <li class="text-sm">
                    <%= link_to index_path, class: "flex items-center px-3 py-2 text-gray-300 rounded-lg hover:bg-gray-800 hover:text-white transition-all duration-200" do %>
                        <i class="fas fa-box mr-3 w-4"></i>
                        <span>Tabla de productos</span>
                    <% end %>
                </li>
                <%end%>

                <!-- Section Divider -->
                <div class="section border-b pt-4 mb-4 text-xs text-gray-600 border-gray-700 pb-1 pl-3">
                    Configuraciones Generales
                </div>

                <!-- Config Items -->
                <% if has_permission?('Categorias', 'Ver') %>
                    <li class="text-sm">
                        <%= link_to show_category_path, class: "flex items-center px-3 py-2 text-gray-300 rounded-lg hover:bg-gray-800 hover:text-white transition-all duration-200" do %>
                            <i class="fas fa-tags mr-3 w-4"></i>
                            <span>Categorías</span>
                        <% end %>
                    </li>
                <%end%>
                <% if has_permission?('Almacenes', 'Ver') %>
                    <li class="text-sm">
                        <%= link_to show_warehouses_path, class: "flex items-center px-3 py-2 text-gray-300 rounded-lg hover:bg-gray-800 hover:text-white transition-all duration-200" do %>
                            <i class="fas fa-warehouse mr-3 w-4"></i>
                            <span>Almacenes</span>
                        <% end %>
                    </li>
                <%end%>
                <% if has_permission?('Tallas', 'Ver') %>
                    <li class="text-sm">
                        <%= link_to show_size_path, class: "flex items-center px-3 py-2 text-gray-300 rounded-lg hover:bg-gray-800 hover:text-white transition-all duration-200" do %>
                            <i class="fas fa-ruler mr-3 w-4"></i>
                            <span>Tallas</span>
                        <% end %>
                    </li>
                <%end%>
                <% if has_permission?('Usuarios', 'Ver') %>
                    <li class="text-sm">
                        <%= link_to show_user_path, class: "flex items-center px-3 py-2 text-gray-300 rounded-lg hover:bg-gray-800 hover:text-white transition-all duration-200" do %>
                            <i class="fas fa-users mr-3 w-4"></i>
                            <span>Usuarios</span>
                        <% end %>
                    </li>
                <%end%>
                <% if has_permission?('Roles', 'Ver') %>
                    <li class="text-sm">
                        <%= link_to show_roles_path, class: "flex items-center px-3 py-2 text-gray-300 rounded-lg hover:bg-gray-800 hover:text-white transition-all duration-200" do %>
                            <i class="fas fa-user-shield mr-3 w-4"></i>
                            <span>Roles</span>
                        <% end %>
                    </li>
                <%end%>    
                <% if has_permission?('Gestion de Inventario', 'Ver') %>
                    <li class="text-sm">
                        <%= link_to index_inventary_path, class: "flex items-center px-3 py-2 text-gray-300 rounded-lg hover:bg-gray-800 hover:text-white transition-all duration-200" do %>
                            <i class="fas fa-clipboard-list mr-3 w-4"></i>
                            <span>Gestión de Inventario</span>
                        <% end %>
                    </li>
                <%end%>    
                <% if has_permission?('Ventas Directas', 'Ver') %>
                    <li class="text-sm">
                        <%= link_to direct_sales_path, class: "flex items-center px-3 py-2 text-gray-300 rounded-lg hover:bg-gray-800 hover:text-white transition-all duration-200" do %>
                            <i class="fas fa-cash-register mr-3 w-4"></i>
                            <span>Ventas Directas</span>
                        <% end %>
                    </li>
                <%end%> 
                <% if has_permission?('Venta a credito', 'Ver') %>   
                <li class="text-sm">
                    <%= link_to credit_sales_path, class: "flex items-center px-3 py-2 text-gray-300 rounded-lg hover:bg-gray-800 hover:text-white transition-all duration-200" do %>
                        <i class="fas fa-credit-card mr-3 w-4"></i>
                        <span>Venta a Crédito</span>
                    <% end %>
                </li>
                <%end%>
                <!-- Logout -->
               <li class="text-sm mt-4">
                <%= button_to destroy_user_session_path, 
                    method: :delete, 
                    data: { 
                        turbo_method: :delete,
                        turbo_confirm: "¿Estás seguro de que deseas salir?"
                    }, 
                    class: "flex items-center w-full px-3 py-2 text-red-300 rounded-lg hover:bg-red-900 hover:text-white transition-all duration-200" do %>
                    <i class="fas fa-sign-out-alt mr-3 w-4"></i>
                    <span>Salir</span>
                <% end %>
                </li>
            </ul>
        </nav>
    </div>
    <!-- End Sidebar -->

    <!-- Backdrop móvil -->
    <div 
        x-data="{ open: false }" 
        x-on:togglesidebar.window="open = !open"
        x-show="open" 
        x-transition:enter="transition-opacity ease-linear duration-300"
        x-transition:enter-start="opacity-0"
        x-transition:enter-end="opacity-100"
        x-transition:leave="transition-opacity ease-linear duration-300"
        x-transition:leave-start="opacity-100"
        x-transition:leave-end="opacity-0"
        @click="$dispatch('togglesidebar')"
        class="fixed inset-0 bg-black opacity-50 z-40 lg:hidden">
    </div>

    <!-- Content -->
    <div class="flex-1 flex flex-col lg:ml-0">

        <!-- Top Navbar -->
        <nav class="bg-black shadow-xl sticky w-full top-0 z-50" x-data="{ mobilemenu: false }">
            <div class="flex items-stretch justify-between h-16">

                <!-- Mobile Menu Button -->
                <div class="flex items-center md:hidden">
                    <button 
                        type="button" 
                        @click="$dispatch('togglesidebar')" 
                        class="bg-gray-800 inline-flex items-center justify-center p-2 rounded-md text-gray-400 hover:text-white hover:bg-gray-700 focus:outline-none">
                        <span class="sr-only">Open main menu</span>
                        <svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                        </svg>
                    </button>
                </div>

                <!-- Logo -->
                <div class="flex items-center pl-6">
                    <a href="#" class="text-white flex items-center space-x-2">
                        <svg class="h-8 w-8 transition-transform duration-300 group-hover:-rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                        </svg>
                        <div>
                            <span class="text-lg lg:text-2xl font-extrabold">RALPHBOUTIQUE</span>
                            <div class="text-xs text-gray-400">ADMIN</div>
                        </div>
                    </a>
                </div>

                <!-- Search Bar -->
                <form action="" class="hidden lg:block ml-6">
                    <div class="relative">
                        <input type="text" class="form-input bg-gray-700 text-sm text-gray-300 pl-10 py-1.5 border-transparent rounded-md w-48 focus:w-60 focus:outline-none" placeholder="Search...">
                        <span class="absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 1114 0 7 7 0 01-14 0z" />
                            </svg>
                        </span>
                    </div>
                </form>
            </div>
        </nav>

        <!-- Main Content -->
        <main class="bg-[#fcfcfc] mb-auto flex-grow w-full lg:w-auto pl-60 pt-16">
          <div class="px-4 sm:px-6 lg:px-8">
            <%= yield %>
          </div>        
        </main>
    </div>
</div>

</div>
    
      <script src="https://unpkg.com/flowbite@1.5.1/dist/flowbite.js"></script>
  </body>
</html>