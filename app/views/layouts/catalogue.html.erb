<!DOCTYPE html>
<html>
  <head>
    <title>GG Store</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
     <%= stylesheet_link_tag "tailwind", "inter-font", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fancyapps/ui@5.0/dist/fancybox/fancybox.css">
  </head>
  <body class="min-h-screen">
    <nav data-controller="navbar"
         class="navbar font-sans w-full fixed top-0 z-50 transition-all duration-300">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16 lg:h-20">
          
          <!-- Logo -->
          <a href="#" class="flex-shrink-0 flex items-center space-x-3">
            <%= image_tag "GG Store 00 Logo-02.png", alt: "GG_Store", class: "h-12 lg:h-16 w-auto transition-all duration-300" %>
          </a>

          <!-- Desktop Navigation -->
          <div class="hidden md:flex md:items-center md:space-x-1">
            <%= link_to catalogue_path, class: "nav-link" do %>
              <i class="fa-solid fa-house"></i>
              <span>Inicio</span>
            <% end %>

            <%= link_to products_path, class: "nav-link" do %>
              <i class="fa-solid fa-tag"></i>
              <span>Productos</span>
            <% end %>

            <% if @last_articles.present? %>
              <a href="#servicios" class="nav-link">
                <i class="fa-solid fa-headphones"></i>
                <span>Servicios</span>
              </a>
              <a href="#contacto" class="nav-link">
                <i class="fa-solid fa-user"></i>
                <span>Contacto</span>
              </a>
            <% end %>
          </div>

          <!-- Actions -->
          <div class="flex items-center space-x-1">
            <!-- Favorites -->
            <%= link_to favorites_path, class: "cart-btn relative" do %>
              <i class="fa-regular fa-heart text-xl"></i>
              <span class="fav-badge absolute -top-1 -right-1 bg-red-500 text-white text-xs font-bold rounded-full min-w-[18px] h-[18px] flex items-center justify-center px-1 hidden">0</span>
            <% end %>

            <!-- Cart -->
            <%= link_to cart_path, class: "cart-btn relative" do %>
              <i class="fa-solid fa-cart-shopping text-xl"></i>
              <span class="cart-badge absolute -top-1 -right-1 bg-red-500 text-white text-xs font-bold rounded-full min-w-[18px] h-[18px] flex items-center justify-center px-1 hidden">0</span>
            <% end %>

            <!-- Mobile Hamburger -->
            <button data-action="navbar#toggleMobile"
                    data-navbar-target="hamburger"
                    class="hamburger md:hidden relative w-10 h-10 flex items-center justify-center rounded-lg hover:bg-white/10 transition-colors duration-200 focus:outline-none"
                    aria-label="Menu">
              <span class="hamburger-line"></span>
              <span class="hamburger-line"></span>
              <span class="hamburger-line"></span>
            </button>
          </div>
        </div>
      </div>

      <!-- Mobile Menu Overlay -->
      <div data-navbar-target="overlay"
           data-action="click->navbar#closeMobile"
           class="overlay hidden opacity-0 transition-opacity duration-300"></div>

      <!-- Mobile Menu -->
      <div data-navbar-target="mobileMenu"
           class="mobile-menu translate-x-full transition-transform duration-300 ease-in-out">
        <div class="flex items-center justify-between p-4 border-b border-white/10">
          <span class="font-semibold text-lg" style="color:#6B3A5A;">Menu</span>
          <button data-action="navbar#toggleMobile"
                  class="w-8 h-8 flex items-center justify-center rounded-lg hover:bg-white/50 transition-colors" style="color:rgba(120,70,90,0.7);">
            <i class="fa-solid fa-xmark text-xl"></i>
          </button>
        </div>
        <div class="p-4 space-y-1">
          <%= link_to catalogue_path, class: "mobile-link", data: { action: "navbar#closeMobile" } do %>
            <i class="fa-solid fa-house w-6"></i>
            <span>Inicio</span>
          <% end %>

          <%= link_to products_path, class: "mobile-link", data: { action: "navbar#closeMobile" } do %>
            <i class="fa-solid fa-tag w-6"></i>
            <span>Productos</span>
          <% end %>

          <% if @last_articles.present? %>
            <a href="#servicios" data-action="navbar#closeMobile" class="mobile-link">
              <i class="fa-solid fa-headphones w-6"></i>
              <span>Servicios</span>
            </a>
            <a href="#contacto" data-action="navbar#closeMobile" class="mobile-link">
              <i class="fa-solid fa-user w-6"></i>
              <span>Contacto</span>
            </a>
          <% end %>

          <hr class="my-4" style="border-color:rgba(200,150,180,0.2);">

          <%= link_to favorites_path, class: "mobile-link", data: { action: "navbar#closeMobile" } do %>
            <i class="fa-regular fa-heart w-6"></i>
            <span>Favoritos</span>
          <% end %>

          <%= link_to cart_path, class: "mobile-link", data: { action: "navbar#closeMobile" } do %>
            <i class="fa-solid fa-cart-shopping w-6"></i>
            <span>Carrito</span>
          <% end %>
        </div>
      </div>
    </nav>
    <div class="pt-16 lg:pt-20">
      <%= yield %>
    </div>
    <!-- Loading overlay for Turbo -->
    <div id="loading-overlay" class="fixed inset-0 z-[200] bg-white/80 backdrop-blur-sm flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300">
      <div class="flex flex-col items-center gap-4">
        <div class="w-10 h-10 border-4 border-rose-200 border-t-rose-300 rounded-full animate-spin"></div>
        <p class="text-sm text-gray-500 font-medium">Cargando...</p>
      </div>
    </div>

    <!-- Toast container -->
    <div id="toast-container" class="fixed top-20 right-4 z-[100] flex flex-col gap-3 pointer-events-none"></div>

    <script src="https://cdn.jsdelivr.net/npm/@fancyapps/ui@5.0/dist/fancybox/fancybox.umd.js"></script>
    <script src="https://unpkg.com/flowbite@1.5.1/dist/flowbite.js"></script>
    <script src="https://unpkg.com/scrollreveal"></script>
    <script>
      function showToast(message, type) {
        var container = document.getElementById('toast-container');
        if (!container) return;
        var colors = { success: 'bg-green-600', error: 'bg-red-500', info: 'bg-rose-300' };
        var icons = { success: 'fa-check-circle', error: 'fa-xmark-circle', info: 'fa-circle-info' };
        var bg = colors[type] || colors.info;
        var icon = icons[type] || icons.info;
        var toast = document.createElement('div');
        toast.className = bg + ' text-white px-5 py-3.5 rounded-xl shadow-2xl flex items-center gap-3 text-sm font-medium pointer-events-auto translate-y-4 opacity-0 transition-all duration-400 ease-out';
        toast.innerHTML = '<div class="flex-shrink-0 w-8 h-8 flex items-center justify-center rounded-full bg-white/20"><i class="fa-solid ' + icon + ' text-lg"></i></div><span>' + message + '</span>';
        container.appendChild(toast);
        requestAnimationFrame(function() {
          toast.classList.remove('translate-y-4', 'opacity-0');
          toast.classList.add('translate-y-0', 'opacity-100');
        });
        setTimeout(function() {
          toast.classList.add('translate-y-4', 'opacity-0');
          setTimeout(function() { toast.remove(); }, 400);
        }, 3000);
      }

      function updateCartBadge() {
        try {
          var cart = JSON.parse(localStorage.getItem('ralph_cart')) || []
          var count = cart.reduce(function(s, i) { return s + (parseInt(i.quantity) || 0); }, 0)
          var badge = document.querySelector('.cart-badge')
          if (badge) {
            if (count > 0) {
              badge.textContent = count
              badge.classList.remove('hidden')
            } else {
              badge.classList.add('hidden')
            }
          }
        } catch(e) {}
      }

      function updateFavBadge() {
        try {
          var favs = JSON.parse(localStorage.getItem('ralph_favorites')) || []
          var badge = document.querySelector('.fav-badge')
          if (badge) {
            if (favs.length > 0) {
              badge.textContent = favs.length
              badge.classList.remove('hidden')
            } else {
              badge.classList.add('hidden')
            }
          }
        } catch(e) {}
      }

      function buildSkeletonGrid(container, count, cols) {
        var html = '<div class="grid ' + cols + ' gap-6 mb-12">';
        for (var i = 0; i < count; i++) {
          html += '<div class="skeleton-card"><div class="skeleton h-64 w-full rounded-none"></div><div class="p-6 space-y-3"><div class="skeleton h-3 w-1/4"></div><div class="skeleton h-5 w-3/4"></div><div class="skeleton h-4 w-1/3"></div><div class="flex justify-between"><div class="skeleton h-7 w-1/4"></div><div class="skeleton h-4 w-1/5"></div></div><div class="skeleton h-11 w-full rounded-xl"></div></div></div>';
        }
        html += '</div>';
        container.innerHTML = html;
      }

      // Turbo loading skeleton
      document.addEventListener('turbo:before-visit', function() {
        var main = document.querySelector('.pt-16 > div:first-child');
        if (main) {
          var skeletonZone = document.getElementById('turbo-skeleton');
          if (!skeletonZone) {
            skeletonZone = document.createElement('div');
            skeletonZone.id = 'turbo-skeleton';
            main.parentNode.insertBefore(skeletonZone, main);
          }
          var isGrid = main.querySelector('.grid');
          if (isGrid) {
            var cols = 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4';
            if (main.querySelector('.lg\\:grid-cols-3')) cols = 'grid-cols-1 md:grid-cols-2 lg:grid-cols-3';
            buildSkeletonGrid(skeletonZone, 8, cols);
          } else {
            skeletonZone.innerHTML = '<div class="max-w-7xl mx-auto px-4 py-12"><div class="skeleton h-8 w-64 mb-8"></div><div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">' + Array(8).fill('<div class="skeleton-card"><div class="skeleton h-64 w-full rounded-none"></div><div class="p-6 space-y-3"><div class="skeleton h-3 w-1/4"></div><div class="skeleton h-5 w-3/4"></div><div class="skeleton h-4 w-1/3"></div><div class="skeleton h-7 w-1/4"></div><div class="skeleton h-11 w-full rounded-xl"></div></div></div>').join('') + '</div></div>';
          }
          main.style.display = 'none';
        }
      });
      document.addEventListener('turbo:load', function() {
        var skeletonZone = document.getElementById('turbo-skeleton');
        if (skeletonZone) skeletonZone.remove();
        var main = document.querySelector('.pt-16 > div:first-child');
        if (main) main.style.display = '';
        var overlay = document.getElementById('loading-overlay');
        if (overlay) {
          overlay.classList.add('opacity-0', 'pointer-events-none');
          overlay.classList.remove('opacity-100', 'pointer-events-auto');
        }
        updateCartBadge();
        updateFavBadge();
      });
      document.addEventListener('DOMContentLoaded', function() {
        updateCartBadge();
        updateFavBadge();
      });
      window.addEventListener('storage', function() {
        updateCartBadge();
        updateFavBadge();
      });
    </script>
  </body>
</html>
<style>
  /* ==============================
     NAVBAR MODERNO - GG STORE
     ============================== */

  /* Base navbar - glass morphism */
  .navbar {
    background: linear-gradient(135deg, rgba(245, 215, 220, 0.75), rgba(235, 200, 215, 0.8), rgba(225, 185, 210, 0.85));
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.25);
    box-shadow: 0 4px 30px rgba(200, 150, 180, 0.15);
    transition: all 0.3s ease;
  }

  .navbar.scrolled {
    background: linear-gradient(135deg, rgba(235, 195, 205, 0.92), rgba(220, 180, 200, 0.94), rgba(210, 170, 195, 0.96));
    border-bottom-color: rgba(200, 150, 180, 0.1);
    box-shadow: 0 8px 40px rgba(200, 150, 180, 0.2);
  }

  /* Desktop nav links */
  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 0.875rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: rgba(120, 70, 90, 0.85);
    border-radius: 0.5rem;
    transition: all 0.2s ease;
    position: relative;
    white-space: nowrap;
  }

  .nav-link:hover {
    color: #6B3A5A;
    background: rgba(255, 255, 255, 0.6);
    transform: translateY(-1px);
  }

  .nav-link i {
    font-size: 0.9rem;
    opacity: 0.6;
    transition: opacity 0.2s;
  }

  .nav-link:hover i {
    opacity: 1;
  }

  .nav-link-dropdown {
    padding-right: 0.75rem;
  }

  /* Dropdown menu */
  .dropdown-menu {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(200, 150, 180, 0.2);
    border-radius: 1rem;
    box-shadow: 0 25px 60px rgba(200, 150, 180, 0.2);
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    animation: dropdownIn 0.2s ease-out;
  }

  @keyframes dropdownIn {
    from {
      opacity: 0;
      transform: translateX(-50%) translateY(8px) scale(0.96);
    }
    to {
      opacity: 1;
      transform: translateX(-50%) translateY(0) scale(1);
    }
  }

  .dropdown-link {
    display: block;
    padding: 0.4rem 0.75rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: rgba(120, 70, 90, 0.7);
    border-radius: 0.375rem;
    transition: all 0.2s ease;
    letter-spacing: 0.01em;
  }

  .dropdown-link:hover {
    color: #6B3A5A;
    background: rgba(245, 215, 220, 0.4);
    padding-left: 1rem;
  }

  /* Cart button */
  .cart-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    color: rgba(120, 70, 90, 0.8);
    border-radius: 0.75rem;
    transition: all 0.2s ease;
    position: relative;
  }

  .cart-btn:hover {
    color: #6B3A5A;
    background: rgba(255, 255, 255, 0.5);
    transform: translateY(-1px);
  }

  /* Animated hamburger */
  .hamburger {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
  }

  .hamburger-line {
    display: block;
    width: 20px;
    height: 2px;
    background: #6B3A5A;
    border-radius: 2px;
    transition: all 0.3s ease;
  }

  .hamburger.active .hamburger-line:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }

  .hamburger.active .hamburger-line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }

  .hamburger.active .hamburger-line:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  /* Mobile menu overlay */
  .overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: 40;
  }

  /* Mobile menu panel */
  .mobile-menu {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: 18rem;
    max-width: 85vw;
    background: linear-gradient(180deg, rgba(245, 215, 220, 0.98), rgba(225, 190, 210, 0.99));
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border-left: 1px solid rgba(200, 150, 180, 0.15);
    z-index: 50;
    overflow-y: auto;
    box-shadow: -10px 0 40px rgba(200, 150, 180, 0.25);
  }

  .mobile-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: rgba(120, 70, 90, 0.8);
    border-radius: 0.75rem;
    transition: all 0.2s ease;
  }

  .mobile-link:hover {
    color: #6B3A5A;
    background: rgba(255, 255, 255, 0.5);
  }

  .mobile-sub-link {
    display: block;
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    color: rgba(120, 70, 90, 0.6);
    border-radius: 0.5rem;
    transition: all 0.2s ease;
  }

  .mobile-sub-link:hover {
    color: #6B3A5A;
    background: rgba(245, 215, 220, 0.4);
  }

  /* ==============================
     HERO IMAGE - KEN BURNS EFFECT
     ============================== */

  .hero-image-container {
    overflow: hidden;
  }

  .hero-image {
    animation: kenBurns 25s ease-in-out infinite alternate;
    will-change: transform;
  }

  @keyframes kenBurns {
    0% {
      transform: scale(1) translate(0, 0);
    }
    50% {
      transform: scale(1.08) translate(-1%, -1%);
    }
    100% {
      transform: scale(1.12) translate(1%, 1%);
    }
  }

  /* ==============================
     EXISTING STYLES (preserved)
     ============================== */

  .avatar {
    overflow: hidden;
    box-shadow: 0 5px 15px 0px rgba(0,0,0,0.6);
    transform: translatey(0px);
    animation: float 6s ease-in-out infinite;
  }
  .avatar img { width: 100%; height: auto; }

  .heart-btn{
    box-shadow: 0px 0px 0px 0px rgba(0,0,0,0.75);
    animation: heartbeat 1s infinite;
  }

  @keyframes heartbeat {
    0% { transform: scale(1); 
    box-shadow: 0px 0px 0px 0px rgba(0,0,0,0.75);
    }
    50% { transform: scale(1.05);
    box-shadow: 0px 0px 0px 0px rgba(255,0,0,0.5);
    }
    100% { transform: scale(1); 
    box-shadow: 0px 0px 0px 0px rgba(0,0,0,0.75);
    }
  }

  @keyframes typing {
    0% { width: 0; }
    50% { width: 100%; }
    100% { width: 0; }
  }

  .typing-animation {
    display: inline-block;
    overflow: hidden;
    white-space: nowrap;
    border-right: 3px solid black;
    animation: typing 10s steps(180, end) infinite;
  }

  @keyframes slideInLeft {
    from { transform: translateX(-100%); opacity: 0; }
    to { transform: translateX(0); opacity: 1; }
  }

  @keyframes slideInRight {
    from { transform: translateX(100%); opacity: 0; }
    to { transform: translateX(0); opacity: 1; }
  }

  @keyframes slideInBottom {
    from { transform: translateY(100%); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  .slide-in-left { animation: slideInLeft 2.5s ease-out forwards infinite; }
  .slide-in-right { animation: slideInRight 2.5s ease-out forwards infinite; }
  .slide-in-bottom { animation: slideInBottom 2.5s ease-out forwards infinite; }

  @keyframes fadeIn {
    0% { opacity: 0; transform: translateY(40px); }
    50% { opacity: 1; transform: translateY(10); }
    100% { opacity: 0; transform: translateY(-30px); }
  }

  .fade-in { animation: fadeIn 6s ease-in-out infinite; }

  @keyframes blob {
    0%, 100% { transform: translate(0px, 0px) scale(1); }
    33% { transform: translate(30px, -50px) scale(1.1); }
    66% { transform: translate(-20px, 20px) scale(0.9); }
  }

  .animate-blob { animation: blob 7s infinite; }
  .animation-delay-2000 { animation-delay: 2s; }
  .animation-delay-4000 { animation-delay: 4s; }

  @keyframes fade-in-up {
    0% { opacity: 0; transform: translateY(30px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  .animate-fade-in-up { animation: fade-in-up 0.8s ease-out forwards; }

  @keyframes typing-effect {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0.7; }
  }

  .typing-effect { animation: typing-effect 2s ease-in-out infinite; }

  .line-clamp-2 {
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .aspect-square { aspect-ratio: 1 / 1; }

  .group:hover .group-hover\:scale-110 { transform: scale(1.1); }
  .group:hover .group-hover\:translate-x-1 { transform: translateX(0.25rem); }
  .group:hover .group-hover\:translate-x-2 { transform: translateX(0.5rem); }

  .backdrop-blur-sm {
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  /* ==============================
     SKELETON LOADING
     ============================== */

  .skeleton {
    background: linear-gradient(90deg, #e5e7eb 25%, #f3f4f6 50%, #e5e7eb 75%);
    background-size: 200% 100%;
    animation: skeleton-pulse 1.5s ease-in-out infinite;
    border-radius: 0.5rem;
  }

  @keyframes skeleton-pulse {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  .skeleton-card {
    background: white;
    border-radius: 1rem;
    overflow: hidden;
    border: 1px solid #f3f4f6;
  }
</style>
<script>
  function addToCart(product) {
  let cartItems = JSON.parse(localStorage.getItem('cartItems')) || [];
  if (!cartItems.find(item => item.id === product.id)) {
    cartItems.push(product);
    localStorage.setItem('cartItems', JSON.stringify(cartItems));
    
    fetch('/cart/add', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content')
      },
      body: JSON.stringify({ item: product })
    }).then(response => response.json())
      .then(data => console.log(data.message));
  }
}

function removeFromCart(productId) {
  let cartItems = JSON.parse(localStorage.getItem('cartItems')) || [];
  cartItems = cartItems.filter(item => item.id !== productId);
  localStorage.setItem('cartItems', JSON.stringify(cartItems));

  fetch('/cart/remove', {
    method: 'DELETE',
    headers: {
      'Content-Type': 'application/json',
      'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content')
    },
    body: JSON.stringify({ item: { id: productId } })
  }).then(response => response.json())
    .then(data => console.log(data.message));
}

document.addEventListener('DOMContentLoaded', function() {
  const buttons = document.querySelectorAll('.add-to-cart');

  buttons.forEach(button => {
    button.addEventListener('click', function(event) {
      event.preventDefault();

      const articleId = this.dataset.id;
      const title = this.dataset.title;
      const price = this.dataset.price;
      const image = this.dataset.image;

      let cart = JSON.parse(localStorage.getItem('cart')) || [];

      const existingArticle = cart.find(item => item.id === articleId);

      if (existingArticle) {
        existingArticle.quantity += 1;
      } else {
        cart.push({ id: articleId, title, price, image, quantity: 1 });
      }

      localStorage.setItem('cart', JSON.stringify(cart));
      alert('Artículo añadido al carrito');
    });
  });
});
</script>