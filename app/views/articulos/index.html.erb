<div class="flex justify-between mt-10 mx-24">
    <div class="flex">
        <%= form_with(url: index_path, method: :get, local: true, class: ' flex items-center') do %>
            <%= text_field_tag :query, params[:query], class: 'rounded-xl search-input' %>
            <%= button_tag(type: 'submit', class: 'search-button ml-3') do %>
            <i class="fas fa-search"></i>
            <% end %>
        <% end %>  
         <div class="">
            <%= link_to index_path, class: " mt-3 ml-3 flex items-center" do %>
                <i class="fa fa-retweet" aria-hidden="true"></i>
            <% end %>
        </div>
    </div>
    <div class="">
        <%= link_to new_path, class: "rounded-md bg-pink-400 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-pink-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-pink-600 flex items-center" do %>
            Nuevo artículo <i class="fa fa-plus ml-2" aria-hidden="true"></i>
        <% end %>
    </div>
</div>
<div class="relative overflow-x-auto container mt-7 ml-36">
    <table class="w-full text-sm text-left rtl:text-right text-gray-500 dark:text-gray-400">
        <thead class="text-xs text-gray-700 uppercase bg-pink-100 dark:text-gray-400">
            <tr>
                <th scope="col" class="px-6 py-3">
                    Nombre del Articulo
                </th>
                <th scope="col" class="px-6 py-3">
                    PRECIO
                </th>
                <th scope="col" class="px-6 py-3">
                    CATEGORIA
                </th>
                 <th>
                    IMAGEN
                </th>
                <th scope="col" class="px-6 py-3">
                    ACCION
                </th>
            </tr>
        </thead>
        <tbody>
            <% @articles.each do |article|%>
            <tr class="bg-white border-b article">
                <th scope="row" class="px-6 py-4 font-medium text-gray-900 whitespace-nowrap">
                    <%= article.title%>
                </th>
                <td class="px-6 py-4">
                    <%= article.price%> $
                </td> 
                <td class="px-6 py-4">
                    <%= article.category.title%>
                </td>
                 <td class="px-6 py-4 whitespace-no-wrap">
                    <% if article.image.attached? %>
                        <%= image_tag article.image, style: "width: 100px; height: 10%;" %>
                    <% end %>
                </td>
                <td class="px-6 py-4">
                    <a href="<%= edit_article_path(article.id) %>" method="delete" data-confirm="¿Estás seguro?" class="bg-purple-500 hover:bg-gray-700 text-white font-bold py-2 px-4 rounded">
                        <i class="fas fa-pencil"></i>
                    </a>
                    <%= link_to delete_article_path(article.id), method: :delete, data: { confirm: '¿Estás seguro?' }, class: 'bg-gray-500 hover:bg-gray-700 text-white font-bold py-2 px-4 rounded' do %>
                        <i class="fas fa-trash"></i>
                    <% end %>
                </td>
            </tr>
            <% end %>
        </tbody>
    </table>
</div>

<div class="flex justify-center mt-5">
    <%= paginate @articles %>
</div>

