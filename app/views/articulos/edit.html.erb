<div class ="container mx-32">
<%= form_for @article, url: update_article_path(@article) do |f| %>
<div class="space-y-12">
    <div class="mt-10 grid grid-cols-1 gap-x-6 gap-y-8 sm:grid-cols-12">
        <div class="sm:col-span-6 ">
            <%= f.label :title,  "NOMBRE DEL ARTICULO" ,class: "block text-sm font-medium leading-6 text-gray-900" %>
            <div class="mt-2">
                <%= f.text_field :title , class:"block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6"%>
            </div>
        </div>
        <div class="sm:col-span-3">
            <%= f.label :serial,  "SERIAL" ,class: "block text-sm font-medium leading-6 text-gray-900" %>
            <div class="mt-2">
                <%= f.text_field :serial , class:"block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6"%>
            </div>
        </div>
        <div class="sm:col-span-3">
            <%= f.label :price,  "PRECIO" ,class: "block text-sm font-medium leading-6 text-gray-900" %>
            <div class="mt-2">
                <%= f.number_field :price , class:"block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6"%>
            </div>
        </div>
        <div class="sm:col-span-3">
            <%# <label for="country" class="block text-sm font-medium leading-6 text-gray-900">ALMACEN</label> %>
            <div class="mt-2">
                    <%= f.label :werehouse_id, "ALMACEN", class: "block text-sm font-medium leading-6 text-gray-900" %>
                <div class="mt-2">
                    <%= f.select :werehouse_id, @werehouses.collect {|c| [c.title , c.id]}, prompt: "Seleccionar Almacen", class: "block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:max-w-xs sm:text-sm sm:leading-6" %>
                </div>
            </div>
        </div>
        <div class="sm:col-span-3">
            <%= f.label :category_id,"CATEGORIA", class: "block text-sm font-medium leading-6 text-gray-900" %>
            <div class="mt-2">
                <%= f.select :category_id, @categories.collect { |c| [ c.title, c.id] }, prompt: "Seleccionar categoría", class: "block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:max-w-xs sm:text-sm sm:leading-6" %>
            </div>
        </div>
            <div class="sm:col-span-3">
            <%= f.label :size_id,"TALLA" ,class: "block text-sm font-medium leading-6 text-gray-900" %>
            <div class="mt-2">
                <%= f.select :size_id, @sizes.collect { |c| [ c.title, c.id] }, prompt: "Seleccionar talla", class: "block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:max-w-xs sm:text-sm sm:leading-6" %>
            </div>
        </div>
            <div class="sm:col-span-3">
            <%= f.label :color_id,"COLOR", class: "block text-sm font-medium leading-6 text-gray-900" %>
            <div class="mt-2">
                <%= f.select :color_id, @colors.collect { |c| [ c.title, c.id] }, prompt: "Seleccionar color", class: "block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:max-w-xs sm:text-sm sm:leading-6" %>
            </div>
        </div>
    </div>

        <div class="mt-10 grid grid-cols-1 gap-x-6 gap-y-8 sm:grid-cols-6">
                <div class="col-span-full">
                <%= f.label :desciption,"DESCRIPCION DEL PRODUCTO", class: "block text-sm font-medium leading-6 text-gray-900" %>
                <div class="mt-2">
                    <%= f.text_area :desciption, size: "100x5" %>
                </div>
                <p class="mt-3 text-sm leading-6 text-gray-600">Escribe las caracteristicas del producto.</p>
                </div>

                <div class="col-span-full">
                <label for="cover-photo" class="block text-sm font-medium leading-6 text-gray-900">Cover photo</label>
                <div class="mt-2 flex justify-center rounded-lg border border-dashed border-gray-900/25 px-6 py-10">
                        <div class="text-center">
                        <svg class="mx-auto h-12 w-12 text-gray-300" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                <path fill-rule="evenodd" d="M1.5 6a2.25 2.25 0 012.25-2.25h16.5A2.25 2.25 0 0122.5 6v12a2.25 2.25 0 01-2.25 2.25H3.75A2.25 2.25 0 011.5 18V6zM3 16.06V18c0 .414.336.75.75.75h16.5A.75.75 0 0021 18v-1.94l-2.69-2.689a1.5 1.5 0 00-2.12 0l-.88.879.97.97a.75.75 0 11-1.06 1.06l-5.16-5.159a1.5 1.5 0 00-2.12 0L3 16.061zm10.125-7.81a1.125 1.125 0 112.25 0 1.125 1.125 0 01-2.25 0z" clip-rule="evenodd" />
                        </svg>
                        <div class="mt-4 flex text-sm leading-6 text-gray-600">
                                <%= f.label :image %>
                                <%= f.file_field :image %>
                                <p class="pl-1">or drag and drop</p>
                        </div>
                        <p class="text-xs leading-5 text-gray-600">PNG, JPG, GIF up to 10MB</p>
                        </div>
                        
                </div>
                    <div class="mt-6  mb-14 flex items-center justify-end gap-x-6">
                        <%= link_to "Cancelar", index_path %>
                        <%= f.submit "Editar Articulo", class:"rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600" %>
                    </div>
            </div>
        </div>
	</div>
<% end %>
</div>