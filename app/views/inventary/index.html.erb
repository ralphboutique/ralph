<!-- Header Section -->
<div class="mb-8">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
    <h1 class="text-2xl lg:text-3xl font-bold text-gray-900">Inventario de Artículos</h1>
  </div>

  <!-- Search and Filters Section -->
  <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-200 mb-6">
    <h3 class="text-lg font-medium text-gray-900 mb-4">Búsqueda y Filtros</h3>
    
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
      <!-- Search Form -->
      <div class="lg:col-span-1">
        <%= form_with(url: index_inventary_path, method: :get, local: true, class: 'flex gap-2') do %>
          <%= text_field_tag :query, params[:query], 
              placeholder: "Buscar artículos...",
              class: 'flex-1 px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent' %>
          <%= button_tag(type: 'submit', class: 'px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors duration-200') do %>
            <i class="fas fa-search"></i>
          <% end %>
          <%= link_to index_inventary_path, class: "p-2 text-gray-600 hover:text-blue-600 transition-colors duration-200" do %>
            <i class="fas fa-sync-alt"></i>
          <% end %>
        <% end %>
      </div>

      <!-- Warehouse Filter -->
      <div class="lg:col-span-1">
        <%= form_with(url: index_inventary_path, method: :get, local: true, class: 'flex gap-2') do %>
          <%= select_tag :warehouse_id, 
              options_from_collection_for_select(@warehouses, :id, :title, params[:warehouse_id]), 
              include_blank: "Todos los almacenes", 
              class: "flex-1 px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
          <%= hidden_field_tag :query, params[:query] %>
          <%= submit_tag "Filtrar", class: "px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors duration-200" %>
        <% end %>
      </div>

      <!-- PDF Export -->
      <div class="lg:col-span-1 flex justify-end">
        <%= link_to generate_pdf_path(format: :pdf, warehouse_id: params[:warehouse_id], query: params[:query]), 
                    class: "inline-flex items-center px-4 py-2 bg-red-600 text-white font-medium rounded-lg hover:bg-red-700 transition-colors duration-200" do %>
          <i class="fas fa-file-pdf mr-2"></i>
          Generar PDF
        <% end %>
      </div>
    </div>
  </div>
</div>
<!-- Inventory Table -->
<div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full table-auto">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Artículo</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Precio</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Categoría</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Imagen</th>
          <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">Stock</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @articles.each do |article| %>
          <tr class="hover:bg-gray-50 transition-colors duration-150">
            <!-- Article Name -->
            <td class="px-4 py-4">
              <div class="flex items-center">
                <div class="flex-shrink-0 h-8 w-8">
                  <div class="h-8 w-8 bg-blue-100 rounded-lg flex items-center justify-center">
                    <i class="fas fa-box text-blue-600 text-sm"></i>
                  </div>
                </div>
                <div class="ml-4">
                  <div class="text-sm font-medium text-gray-900">
                    <%= article.title %>
                  </div>
                </div>
              </div>
            </td>
            
            <!-- Price -->
            <td class="px-4 py-4">
              <div class="text-sm font-medium text-gray-900">
                $<%= number_with_delimiter(article.price) %>
              </div>
            </td>
            
            <!-- Category -->
            <td class="px-4 py-4">
              <span class="inline-flex px-2 py-1 text-xs font-semibold text-blue-800 bg-blue-100 rounded-full">
                <%= article.category.title %>
              </span>
            </td>
            
            <!-- Image -->
            <td class="px-4 py-4">
              <% if article.attachment.attached? %>
                <div class="flex-shrink-0 h-16 w-16">
                  <%= image_tag article.attachment, class: "h-16 w-16 object-cover rounded-lg border border-gray-200" %>
                </div>
              <% else %>
                <div class="flex-shrink-0 h-16 w-16 bg-gray-100 rounded-lg border border-gray-200 flex items-center justify-center">
                  <i class="fas fa-image text-gray-400"></i>
                </div>
              <% end %>
            </td>
            
            <!-- Stock/Quantity -->
            <td class="px-4 py-4 text-center">
              <% if article.quantity > 10 %>
                <span class="inline-flex px-2 py-1 text-xs font-semibold text-green-800 bg-green-100 rounded-full">
                  <i class="fas fa-check-circle text-green-600 mr-1"></i>
                  <%= article.quantity %> unidades
                </span>
              <% elsif article.quantity > 0 %>
                <span class="inline-flex px-2 py-1 text-xs font-semibold text-yellow-800 bg-yellow-100 rounded-full">
                  <i class="fas fa-exclamation-triangle text-yellow-600 mr-1"></i>
                  <%= article.quantity %> unidades
                </span>
              <% else %>
                <span class="inline-flex px-2 py-1 text-xs font-semibold text-red-800 bg-red-100 rounded-full">
                  <i class="fas fa-times-circle text-red-600 mr-1"></i>
                  Sin stock
                </span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<!-- Pagination -->
<div class="flex justify-center mt-8">
  <div class="bg-white px-4 py-3 rounded-lg shadow-sm border border-gray-200">
    <%= paginate @articles %>
  </div>
</div>