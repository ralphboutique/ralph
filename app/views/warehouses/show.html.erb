<!-- Header Section Responsive -->
<div class="mb-8">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <!-- Search Section -->
    <div class="flex items-center gap-3">
      <%= form_with(url: show_warehouses_path, method: :get, local: true, class: 'flex items-center gap-2') do %>
        <%= text_field_tag :query, params[:query], 
            placeholder: "Buscar almacenes...",
            class: 'px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent w-full sm:w-64' %>
        <%= button_tag(type: 'submit', class: 'px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors duration-200') do %>
          <i class="fas fa-search"></i>
        <% end %>
      <% end %>
      
      <%= link_to show_warehouses_path, class: "p-2 text-gray-600 hover:text-blue-600 transition-colors duration-200" do %>
        <i class="fas fa-sync-alt"></i>
      <% end %>
    </div>
    
    <!-- New Warehouse Button -->
    <% if has_permission?('Almacenes', 'Crear') %>
      <div class="flex-shrink-0">
        <%= link_to new_warehouses_path, class: "inline-flex items-center px-4 py-2 bg-orange-600 text-white font-medium rounded-lg hover:bg-orange-700 transition-colors duration-200 shadow-sm" do %>
          <i class="fas fa-plus mr-2"></i>
          <span class="hidden sm:inline">Nuevo almacén</span>
          <span class="sm:hidden">Nuevo</span>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<!-- Alerts Section -->
<div class="mb-6">
  <% if notice %>
    <div id="alert-message" data-controller="alert" class="mb-4 p-4 bg-green-50 border border-green-200 text-green-700 rounded-lg">
      <div class="flex items-center">
        <i class="fas fa-check-circle mr-2"></i>
        <%= notice %>
      </div>
    </div>
  <% end %>

  <% if alert %>
    <div id="alert-message" data-controller="alert" class="mb-4 p-4 bg-red-50 border border-red-200 text-red-700 rounded-lg">
      <div class="flex items-center">
        <i class="fas fa-exclamation-circle mr-2"></i>
        <%= alert %>
      </div>
    </div>
  <% end %>
</div>

<!-- Table Container Responsive -->
<div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full table-auto">
        <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
                <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                    ID
                </th>
                <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                    Nombre del Almacén
                </th>
                <th scope="col" class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">
                    Acciones
                </th>
            </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
            <% @warehouses.each do |warehouse|%>
            <tr class="hover:bg-gray-50 transition-colors duration-150">
                <td class="px-4 py-4 whitespace-nowrap">
                    <div class="text-sm font-medium text-gray-900">
                        #<%= warehouse.id %>
                    </div>
                </td>
                <td class="px-4 py-4">
                    <div class="flex items-center">
                        <div class="flex-shrink-0 h-8 w-8">
                            <div class="h-8 w-8 bg-purple-100 rounded-lg flex items-center justify-center">
                                <i class="fas fa-warehouse text-purple-600 text-sm"></i>
                            </div>
                        </div>
                        <div class="ml-4">
                            <div class="text-sm font-medium text-gray-900">
                                <%= warehouse.title %>
                            </div>
                        </div>
                    </div>
                </td>
                <td class="px-4 py-4 text-center">
                    <div class="flex justify-center space-x-2">
                        <% if has_permission?('Almacenes', 'Editar') %>
                            <a href="<%= edit_warehouses_path(warehouse.id) %>" 
                               class="inline-flex items-center justify-center w-8 h-8 bg-gray-100 text-gray-600 rounded-lg hover:bg-gray-200 hover:text-gray-800 transition-colors duration-200"
                               title="Editar">
                                <i class="fas fa-edit text-sm"></i>
                            </a>
                        <% end %>
                        
                        <% if has_permission?('Almacenes', 'Eliminar') %>
                            <%= link_to delete_warehouses_path(warehouse.id), 
                                method: :delete, 
                                data: { 
                                    turbo_method: :delete,
                                    turbo_confirm: "¿Seguro que quieres eliminar este almacén?"
                                }, 
                                class: 'inline-flex items-center justify-center w-8 h-8 bg-red-100 text-red-600 rounded-lg hover:bg-red-200 hover:text-red-800 transition-colors duration-200',
                                title: "Eliminar" do %>
                                <i class="fas fa-trash text-sm"></i>
                            <% end %>
                        <% end %>
                    </div>
                </td>
            </tr>
            <% end %>
        </tbody>
    </table>
  </div>
</div>

<!-- Pagination -->
<div class="flex justify-center mt-8">
  <div class="bg-white px-4 py-3 rounded-lg shadow-sm border border-gray-200">
    <%= paginate @warehouses %>
  </div>
</div>