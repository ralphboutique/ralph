<!-- Featured Products Section Modernizada -->
<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header de la sección -->
    <div class="text-center mb-16">
              <div class="inline-flex items-center px-4 py-2 bg-purple-100 rounded-full text-purple-800 font-semibold text-sm mb-4">
        <i class="fas fa-star mr-2"></i>
        NUEVOS ARRIVALS
      </div>
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">
        Productos
        <span class="bg-gradient-to-r from-blue-600 to-indigo-600 bg-clip-text text-transparent">
          Destacados
        </span>
      </h2>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">
        Las últimas adiciones a nuestra colección exclusiva
      </p>
    </div>

    <!-- Grid de productos -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      <% @last_articles.each_with_index do |article, index| %>
        <div class="group relative bg-white rounded-3xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-500 transform hover:-translate-y-3 animate-fade-in-up" style="animation-delay: <%= index * 0.1 %>s;">
          <!-- Imagen del producto -->
          <div class="relative overflow-hidden aspect-square">
            <% if article.attachment.attached? %>
              <%= image_tag article.attachment, class: "w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" %>
            <% else %>
              <div class="w-full h-full bg-gradient-to-br from-gray-100 to-gray-200 flex items-center justify-center">
                <i class="fas fa-image text-4xl text-gray-400"></i>
              </div>
            <% end %>
            
            <!-- Overlay con botones -->
            <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
              <div class="flex space-x-3">
                <%= link_to details_path(id: article.id, category_id: article.category_id), 
                    class: "flex items-center justify-center w-12 h-12 bg-white/90 backdrop-blur-sm rounded-full text-gray-800 hover:bg-white transition-all duration-300 transform hover:scale-110" do %>
                  <i class="fas fa-eye"></i>
                <% end %>
                
                <a href="https://api.whatsapp.com/send?phone=+584121075579&text=<%= "Hola, estoy interesado en el producto #{article.title} que cuesta $#{article.price}" %>" 
                   target="_blank"
                   class="flex items-center justify-center w-12 h-12 bg-green-500 rounded-full text-white hover:bg-green-600 transition-all duration-300 transform hover:scale-110">
                  <i class="fab fa-whatsapp"></i>
                </a>
              </div>
            </div>
            
            <!-- Badge de nuevo -->
            <div class="absolute top-4 left-4 bg-gradient-to-r from-purple-600 to-pink-600 text-white px-3 py-1 rounded-full text-xs font-semibold">
              NUEVO
            </div>
            
            <!-- Badge de precio -->
            <div class="absolute top-4 right-4 bg-white/90 backdrop-blur-sm text-gray-800 px-3 py-1 rounded-full text-sm font-bold">
              <%= number_to_currency(article.price) %>
            </div>
          </div>
          
          <!-- Información del producto -->
          <div class="p-6">
            <!-- Categoría -->
            <div class="text-purple-600 text-xs font-semibold uppercase tracking-wider mb-2">
              <%= article.category.title %>
            </div>
            
            <!-- Título -->
            <h3 class="font-bold text-lg text-gray-900 mb-3 group-hover:text-purple-600 transition-colors duration-300 line-clamp-2">
              <%= article.title %>
            </h3>
            
            <!-- Rating -->
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center">
                <div class="flex text-yellow-400">
                  <% 5.times do |i| %>
                    <i class="fas fa-star <%= i < 4 ? 'text-yellow-400' : 'text-gray-200' %>"></i>
                  <% end %>
                </div>
                <span class="text-sm text-gray-500 ml-2">(4.0)</span>
              </div>
              
              <!-- Colors disponibles -->
              <div class="flex space-x-1">
                <% article.article_colors.limit(3).each do |color| %>
                  <div class="w-3 h-3 rounded-full border border-gray-300" style="background-color: <%= color.color_hex %>"></div>
                <% end %>
              </div>
            </div>
            
            <!-- Botón de acción -->
            <%= link_to details_path(id: article.id, category_id: article.category_id), 
                class: "w-full inline-flex items-center justify-center px-6 py-3 bg-gradient-to-r from-purple-600 to-pink-600 text-white font-semibold rounded-xl hover:shadow-lg transform transition-all duration-300 hover:scale-105 group-hover:from-pink-600 group-hover:to-purple-600" do %>
              <span>Ver Detalles</span>
              <i class="fas fa-arrow-right ml-2 transition-transform group-hover:translate-x-1"></i>
            <% end %>
          </div>
          
          <!-- Efecto de brillo -->
          <div class="absolute inset-0 bg-gradient-to-t from-transparent via-white/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
        </div>
      <% end %>
    </div>
    
    <!-- Botón ver más productos -->
    <div class="text-center mt-16">
      <%= link_to products_path, 
          class: "inline-flex items-center px-8 py-4 bg-gradient-to-r from-purple-600 to-pink-600 text-white font-semibold rounded-full hover:shadow-xl transform transition-all duration-300 hover:scale-105" do %>
        Ver Toda la Colección
        <i class="fas fa-arrow-right ml-2"></i>
      <% end %>
    </div>
  </div>
</section>
<%= render 'shared/footer'%>

