<!-- Products Page Header -->
<div class="bg-white border-b border-gray-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between">
      
      <!-- Title and Breadcrumb -->
      <div class="mb-6 lg:mb-0">
        <nav class="flex items-center space-x-2 text-sm text-gray-500 mb-4">
          <%= link_to "Inicio", root_path, class: "hover:text-gray-700 transition-colors duration-200" %>
          <i class="fas fa-chevron-right text-xs"></i>
          <span class="text-gray-900 font-medium">Productos</span>
        </nav>
        
        <div class="flex items-center space-x-4">
          <h1 class="text-3xl font-bold text-gray-900">Nuestros Productos</h1>
          <% if @articles&.any? %>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-rose-100 text-rose-700">
              <%= @articles.size %> productos
            </span>
          <% end %>
        </div>
        
        <% if params[:category_id].present? && @category_id.present? %>
          <% category = Category.find_by(id: @category_id) %>
          <% if category %>
            <p class="mt-2 text-gray-600">
              Mostrando productos en: <span class="font-semibold text-gray-900"><%= category.title %></span>
            </p>
          <% end %>
        <% end %>
      </div>

      <!-- Filter and Sort Controls -->
      <div class="flex flex-col sm:flex-row items-stretch sm:items-center space-y-3 sm:space-y-0 sm:space-x-4">
        
        <!-- Category Filter -->
        <% if @categories&.any? %>
          <div class="relative">
            <%= form_with url: products_path, method: :get, local: true, class: "flex items-center space-x-2" do |f| %>
              <%= f.select :category_id, 
                  options_for_select([["Todas las categorías", ""]] + @categories.pluck(:title, :id), params[:category_id]),
                  {},
                  class: "block w-full pl-3 pr-10 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent bg-white",
                  onchange: "this.form.submit();" %>
            <% end %>
          </div>
        <% end %>

        <!-- View Toggle (optional for future implementation) -->
        <div class="flex items-center space-x-1 bg-gray-100 rounded-lg p-1">
          <button class="flex items-center justify-center w-8 h-8 text-blue-600 bg-white rounded-md shadow-sm">
            <i class="fas fa-th text-sm"></i>
          </button>
          <button class="flex items-center justify-center w-8 h-8 text-gray-400 hover:text-gray-600">
            <i class="fas fa-list text-sm"></i>
          </button>
        </div>
      </div>
    </div>

    <!-- Active Filters Display -->
    <% if params[:category_id].present? %>
      <div class="mt-6 flex flex-wrap items-center gap-2">
        <span class="text-sm text-gray-600">Filtros activos:</span>
        
        <% category = Category.find_by(id: params[:category_id]) %>
        <% if category %>
          <span class="inline-flex items-center px-3 py-1 rounded-full text-sm bg-green-100 text-green-800">
            Categoría: <%= category.title %>
            <%= link_to products_path, 
                class: "ml-2 text-green-600 hover:text-green-800" do %>
              <i class="fas fa-times"></i>
            <% end %>
          </span>
        <% end %>
        
        <%= link_to products_path, 
            class: "inline-flex items-center px-3 py-1 text-sm text-gray-600 hover:text-gray-800 transition-colors duration-200" do %>
          <i class="fas fa-times mr-1"></i>
          Limpiar filtros
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<!-- Products Grid Section -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <% if @articles.any? %>
    
    <!-- Products Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 mb-12">
      <% @articles.each do |article| %>
        <div class="group bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-100 hover:border-blue-200" data-product-id="<%= article.id %>">
          
          <!-- Product Image -->
          <div class="relative aspect-w-1 aspect-h-1 bg-gray-50 overflow-hidden">
            <% if article.attachment.attached? %>
              <%= link_to details_path(id: article.id, category_id: article.category_id) do %>
                <%= image_tag article.attachment, 
                    class: "w-full h-64 object-cover group-hover:scale-110 transition-transform duration-500",
                    alt: article.title %>
              <% end %>
            <% else %>
              <div class="w-full h-64 bg-gray-200 flex items-center justify-center">
                <i class="fas fa-image text-gray-400 text-4xl"></i>
              </div>
            <% end %>
            
            <!-- Stock Badge -->
            <div class="absolute top-3 left-3">
              <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800 shadow-sm">
                <i class="fas fa-check-circle mr-1"></i>
                Disponible
              </span>
            </div>
            
            <!-- Favorite Button -->
            <div class="absolute top-3 right-3 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <button data-controller="cart"
                      data-action="cart#toggleFav"
                      data-id="<%= article.id %>"
                      class="flex items-center justify-center w-8 h-8 bg-white rounded-full shadow-lg hover:bg-gray-50 transition-colors duration-200">
                <i class="far fa-heart text-gray-400 hover:text-red-500"></i>
              </button>
            </div>
            
            <!-- Quick View Button -->
            <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/50 to-transparent p-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <%= link_to details_path(id: article.id, category_id: article.category_id),
                  class: "w-full flex items-center justify-center px-4 py-2 text-sm font-medium text-white bg-white/20 backdrop-blur-sm border border-white/30 rounded-lg hover:bg-white/30 transition-colors duration-200" do %>
                <i class="fas fa-eye mr-2"></i>
                Vista rápida
              <% end %>
            </div>
          </div>

          <!-- Product Info -->
          <div class="p-6">
            
            <!-- Category -->
            <% if article.category %>
              <p class="text-xs font-medium text-indigo-600 uppercase tracking-wide mb-2">
                <%= article.category.title %>
              </p>
            <% end %>
            
            <!-- Product Title -->
            <%= link_to details_path(id: article.id, category_id: article.category_id) do %>
              <h3 class="text-lg font-semibold text-gray-900 mb-2 line-clamp-2 group-hover:text-rose-400 transition-colors duration-200">
                <%= article.title %>
              </h3>
            <% end %>
            
            <!-- Rating -->
            <div class="flex items-center mb-3">
              <div class="flex items-center">
                <% 5.times do |i| %>
                  <i class="fas fa-star text-yellow-400 text-sm"></i>
                <% end %>
              </div>
              <span class="ml-2 text-sm text-gray-500">(5.0)</span>
            </div>
            
            <!-- Price -->
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-baseline space-x-1">
                <span class="text-2xl font-bold text-gray-900">
                  $<%= number_with_precision(article.price, precision: 2) %>
                </span>
                <span class="text-sm text-gray-500">USD</span>
              </div>
              
              <!-- Stock indicator -->
              <span class="text-sm text-gray-500">
                <%= article.quantity %> en stock
              </span>
            </div>
            
            <!-- Action Buttons -->
            <div class="space-y-2">
              
              <!-- WhatsApp Button -->
              <a href="https://api.whatsapp.com/send?phone=+584121075579&text=<%= URI.encode_www_form_component("🛍️ ¡Hola! Estoy interesado en:\n\n📦 Producto: #{article.title}\n💰 Precio: $#{article.price}\n🔗 Link: https://ggstore.onrender.com/product/detail/#{article.id}?category_id=#{article.category_id}") %>" 
                 target="_blank"
                 class="w-full flex items-center justify-center px-4 py-3 text-sm font-semibold text-white bg-green-600 hover:bg-green-700 rounded-xl shadow-sm hover:shadow-md transform hover:scale-105 transition-all duration-200">
                <i class="fab fa-whatsapp mr-2"></i>
                Comprar Ahora
              </a>
              
              <!-- View Details Button -->
              <%= link_to details_path(id: article.id, category_id: article.category_id),
                  class: "w-full flex items-center justify-center px-4 py-2 text-sm font-medium text-rose-400 bg-rose-50 hover:bg-rose-100 rounded-xl transition-colors duration-200" do %>
                <i class="fas fa-info-circle mr-2"></i>
                Ver detalles
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Pagination -->
    <div class="flex items-center justify-center">
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 px-6 py-4">
        <%= paginate @articles %>
      </div>
    </div>

  <% else %>
    
    <!-- Empty State -->
    <div class="text-center py-16">
      <div class="max-w-md mx-auto">
        <div class="flex items-center justify-center w-16 h-16 bg-gray-100 rounded-full mx-auto mb-6">
          <i class="fas fa-search text-gray-400 text-2xl"></i>
        </div>
        
        <h3 class="text-xl font-semibold text-gray-900 mb-2">
          No se encontraron productos
        </h3>
        
        <% if params[:category_id].present? %>
          <p class="text-gray-600 mb-6">
            No hay productos en esta categoría. Intenta con otras categorías.
          </p>
          
          <div class="space-y-3">
            <%= link_to products_path, 
                class: "inline-flex items-center px-6 py-3 text-sm font-medium text-white bg-rose-300 hover:bg-rose-400 rounded-lg transition-colors duration-200" do %>
              <i class="fas fa-th mr-2"></i>
              Ver todos los productos
            <% end %>
            
            <div class="text-center">
              <span class="text-gray-500">o</span>
            </div>
            
            <%= link_to root_path, 
                class: "inline-flex items-center px-6 py-3 text-sm font-medium text-gray-600 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors duration-200" do %>
              <i class="fas fa-home mr-2"></i>
              Volver al inicio
            <% end %>
          </div>
        <% else %>
          <p class="text-gray-600 mb-6">
            No hay productos disponibles en este momento. Por favor, vuelve más tarde.
          </p>
          
          <%= link_to root_path, 
              class: "inline-flex items-center px-6 py-3 text-sm font-medium text-white bg-rose-300 hover:bg-rose-400 rounded-lg transition-colors duration-200" do %>
            <i class="fas fa-home mr-2"></i>
            Volver al inicio
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>

<!-- Back Button (if needed) -->
<% if @back == true && @articles.present? %>
  <div class="fixed bottom-6 left-6 z-50">
    <%= link_to products_path, 
        class: "flex items-center justify-center w-12 h-12 bg-white text-gray-600 rounded-full shadow-lg hover:bg-gray-50 hover:shadow-xl transition-all duration-200" do %>
      <i class="fas fa-arrow-left"></i>
    <% end %>
  </div>
<% end %>

<!-- Additional Styles for line-clamp -->
<style>
.line-clamp-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* Custom pagination styles */
.pagination {
  display: flex;
  list-style: none;
  margin: 0;
  padding: 0;
  gap: 0.5rem;
}

.pagination .page-item {
  display: flex;
}

.pagination .page-link {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 2.5rem;
  height: 2.5rem;
  padding: 0;
  color: #6b7280;
  background-color: white;
  border: 1px solid #d1d5db;
  border-radius: 0.5rem;
  text-decoration: none;
  transition: all 0.2s;
}

.pagination .page-link:hover {
  background-color: #f3f4f6;
  color: #374151;
}

.pagination .page-item.active .page-link {
  background-color: #2563eb;
  border-color: #2563eb;
  color: white;
}

.pagination .page-item.disabled .page-link {
  color: #d1d5db;
  cursor: not-allowed;
}
</style>

<!-- JavaScript for enhanced interactions -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  // Smooth scroll for pagination
  const paginationLinks = document.querySelectorAll('.pagination a');
  paginationLinks.forEach(link => {
    link.addEventListener('click', function() {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  });

  // Add to favorites functionality (placeholder)
  const favoriteButtons = document.querySelectorAll('.fas.fa-heart');
  favoriteButtons.forEach(button => {
    button.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      
      if (this.classList.contains('text-red-500')) {
        this.classList.remove('text-red-500');
        this.classList.add('text-gray-400');
      } else {
        this.classList.remove('text-gray-400');
        this.classList.add('text-red-500');
      }
    });
  });
});
</script>