<!-- Favorites Page Header -->
<div class="bg-white border-b border-gray-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between">
      <div class="mb-6 lg:mb-0">
        <nav class="flex items-center space-x-2 text-sm text-gray-500 mb-4">
          <%= link_to "Inicio", catalogue_path, class: "hover:text-gray-700 transition-colors duration-200" %>
          <i class="fas fa-chevron-right text-xs"></i>
          <span class="text-gray-900 font-medium">Mis Favoritos</span>
        </nav>

        <div class="flex items-center space-x-4">
          <h1 class="text-3xl font-bold text-gray-900">Mis Favoritos</h1>
          <span id="fav-count" class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-red-100 text-red-800">0</span>
        </div>
        <p class="mt-2 text-gray-600">Productos que te han gustado</p>
      </div>

      <div class="flex items-center space-x-3">
        <%= link_to products_path, class: "inline-flex items-center px-4 py-2 text-sm font-medium text-gray-600 bg-gray-100 rounded-xl hover:bg-gray-200 transition-colors duration-200" do %>
          <i class="fas fa-arrow-left mr-2"></i>
          Ver todos los productos
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- Products Grid -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 mb-24" id="favorites-container">
  <div id="fav-empty" class="hidden text-center py-20">
    <div class="inline-flex items-center justify-center w-24 h-24 bg-gray-100 rounded-full mb-6">
      <i class="fa-regular fa-heart text-3xl text-gray-300"></i>
    </div>
    <h2 class="text-xl font-semibold text-gray-900 mb-2">No tienes favoritos aún</h2>
    <p class="text-gray-400 mb-8">Explora nuestros productos y guarda tus favoritos</p>
    <%= link_to products_path, class: "inline-flex items-center px-6 py-3 bg-gray-900 text-white font-medium rounded-full hover:bg-gray-800 transition-all duration-200" do %>
      <i class="fas fa-store mr-2"></i>
      Explorar productos
    <% end %>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 mb-12" id="fav-grid">
    <% @articles.each do |article| %>
      <div class="product-card group bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-100 hover:border-red-200" data-product-id="<%= article.id %>">
        <!-- Product Image -->
        <div class="relative aspect-w-1 aspect-h-1 bg-gray-50 overflow-hidden">
          <% if article.attachment.attached? %>
            <%= link_to details_path(id: article.id, category_id: article.category_id) do %>
              <%= image_tag article.attachment,
                  class: "w-full h-64 object-cover group-hover:scale-110 transition-transform duration-500",
                  alt: article.title %>
            <% end %>
          <% else %>
            <div class="w-full h-64 bg-gray-200 flex items-center justify-center">
              <i class="fas fa-image text-gray-400 text-4xl"></i>
            </div>
          <% end %>

          <div class="absolute top-3 left-3">
            <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800 shadow-sm">
              <i class="fas fa-check-circle mr-1"></i>
              Disponible
            </span>
          </div>

          <div class="absolute top-3 right-3">
            <button data-controller="cart"
                    data-action="cart#toggleFav"
                    data-id="<%= article.id %>"
                    class="flex items-center justify-center w-8 h-8 bg-white rounded-full shadow-lg hover:bg-gray-50 transition-colors duration-200">
              <i class="fas fa-heart text-red-500"></i>
            </button>
          </div>

          <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/50 to-transparent p-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            <%= link_to details_path(id: article.id, category_id: article.category_id),
                class: "w-full flex items-center justify-center px-4 py-2 text-sm font-medium text-white bg-white/20 backdrop-blur-sm border border-white/30 rounded-lg hover:bg-white/30 transition-colors duration-200" do %>
              <i class="fas fa-eye mr-2"></i>
              Vista rápida
            <% end %>
          </div>
        </div>

        <div class="p-6">
          <% if article.category %>
            <p class="text-xs font-medium text-indigo-600 uppercase tracking-wide mb-2">
              <%= article.category.title %>
            </p>
          <% end %>

          <%= link_to details_path(id: article.id, category_id: article.category_id) do %>
            <h3 class="text-lg font-semibold text-gray-900 mb-2 line-clamp-2 group-hover:text-red-600 transition-colors duration-200">
              <%= article.title %>
            </h3>
          <% end %>

          <div class="flex items-center mb-3">
            <div class="flex items-center">
              <% 5.times do %>
                <i class="fas fa-star text-yellow-400 text-sm"></i>
              <% end %>
            </div>
            <span class="ml-2 text-sm text-gray-500">(5.0)</span>
          </div>

          <div class="flex items-center justify-between mb-4">
            <div class="flex items-baseline space-x-1">
              <span class="text-2xl font-bold text-gray-900">
                $<%= number_with_precision(article.price, precision: 2) %>
              </span>
              <span class="text-sm text-gray-500">USD</span>
            </div>
            <span class="text-sm text-gray-500">
              <%= article.quantity %> en stock
            </span>
          </div>

          <div class="space-y-2">
            <a href="https://api.whatsapp.com/send?phone=+584121075579&text=<%= URI.encode_www_form_component("Hola, me interesa este producto: #{article.title} - $#{number_with_precision(article.price, precision: 2)} #{request.base_url}#{details_path(id: article.id)}") %>"
               target="_blank"
               class="w-full flex items-center justify-center px-4 py-3 text-sm font-semibold text-white bg-green-600 hover:bg-green-700 rounded-xl shadow-sm hover:shadow-md transform hover:scale-105 transition-all duration-200">
              <i class="fab fa-whatsapp mr-2"></i>
              Comprar Ahora
            </a>

            <%= link_to details_path(id: article.id, category_id: article.category_id),
                class: "w-full flex items-center justify-center px-4 py-2 text-sm font-medium text-red-600 bg-red-50 hover:bg-red-100 rounded-xl transition-colors duration-200" do %>
              <i class="fas fa-info-circle mr-2"></i>
              Ver detalles
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>

<script>
  document.addEventListener('turbo:load', function filterFavorites() {
    var container = document.getElementById('favorites-container');
    if (!container) return;
    var favs = [];
    try { favs = JSON.parse(localStorage.getItem('ralph_favorites')) || []; } catch(e) {}
    var cards = container.querySelectorAll('.product-card');
    var count = 0;
    cards.forEach(function(card) {
      var id = parseInt(card.dataset.productId);
      if (favs.indexOf(id) !== -1) {
        card.classList.remove('hidden');
        count++;
      } else {
        card.classList.add('hidden');
      }
    });
    document.getElementById('fav-count').textContent = count;
    if (count === 0) {
      document.getElementById('fav-empty').classList.remove('hidden');
    } else {
      document.getElementById('fav-empty').classList.add('hidden');
    }
  });
</script>

