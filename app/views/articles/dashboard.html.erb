
<!-- Dashboard Header Responsive -->
<div class="mb-8 pt-6">
  <% if notice %>
    <div id="alert-message" data-controller="alert" class="mb-6 p-4 bg-green-50 border border-green-200 text-green-700 rounded-lg">
      <div class="flex items-center">
        <i class="fas fa-check-circle mr-2"></i>
        <%= notice %>
      </div>
    </div>
  <% end %>
  
  <div class="mb-6">
                    <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-2">GG Store</h1>
    <p class="text-lg text-gray-600">Panel Administrativo - Gestión de Inventario</p>
  </div>
</div>

<!-- Divider -->
<div class="border-b border-gray-200 mb-8"></div>

<!-- Dashboard Cards Grid Responsive -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 mb-8">
  <!-- Card Almacenes -->
  <div class="bg-white shadow-lg rounded-xl p-6 hover:shadow-xl transition-shadow duration-300 border border-gray-100">
    <div class="flex items-center justify-between mb-4">
      <div class="flex items-center">
        <div class="p-3 bg-blue-100 rounded-lg">
          <i class="fas fa-warehouse text-blue-600 text-xl"></i>
        </div>
        <div class="ml-4">
          <h3 class="text-sm font-medium text-gray-500">Total Almacenes</h3>
          <p class="text-2xl font-bold text-gray-900"><%= @total_warehouses %></p>
        </div>
      </div>
    </div>
    <div class="flex items-center text-sm text-gray-500">
      <i class="fas fa-calendar mr-2"></i>
      <%= Date.today.strftime("%d de %B de %Y") %>
    </div>
  </div>

  <!-- Card Artículos -->
  <div class="bg-white shadow-lg rounded-xl p-6 hover:shadow-xl transition-shadow duration-300 border border-gray-100">
    <div class="flex items-center justify-between mb-4">
      <div class="flex items-center">
        <div class="p-3 bg-green-100 rounded-lg">
          <i class="fas fa-box text-green-600 text-xl"></i>
        </div>
        <div class="ml-4">
          <h3 class="text-sm font-medium text-gray-500">Total Artículos</h3>
          <p class="text-2xl font-bold text-gray-900"><%= @total_articles %></p>
        </div>
      </div>
    </div>
    <div class="flex items-center text-sm text-gray-500">
      <i class="fas fa-calendar mr-2"></i>
      <%= Date.today.strftime("%d de %B de %Y") %>
    </div>
  </div>

  <!-- Card Categorías -->
  <div class="bg-white shadow-lg rounded-xl p-6 hover:shadow-xl transition-shadow duration-300 border border-gray-100">
    <div class="flex items-center justify-between mb-4">
      <div class="flex items-center">
        <div class="p-3 bg-purple-100 rounded-lg">
          <i class="fas fa-tags text-purple-600 text-xl"></i>
        </div>
        <div class="ml-4">
          <h3 class="text-sm font-medium text-gray-500">Total Categorías</h3>
          <p class="text-2xl font-bold text-gray-900"><%= @total_categories %></p>
        </div>
      </div>
    </div>
    <div class="flex items-center text-sm text-gray-500">
      <i class="fas fa-calendar mr-2"></i>
      <%= Date.today.strftime("%d de %B de %Y") %>
    </div>
  </div>

  <!-- Card adicional (puedes agregar más estadísticas) -->
  <div class="bg-white shadow-lg rounded-xl p-6 hover:shadow-xl transition-shadow duration-300 border border-gray-100">
    <div class="flex items-center justify-between mb-4">
      <div class="flex items-center">
        <div class="p-3 bg-orange-100 rounded-lg">
          <i class="fas fa-chart-line text-orange-600 text-xl"></i>
        </div>
        <div class="ml-4">
          <h3 class="text-sm font-medium text-gray-500">Sistema Activo</h3>
          <p class="text-lg font-bold text-green-600">Online</p>
        </div>
      </div>
    </div>
    <div class="flex items-center text-sm text-gray-500">
      <i class="fas fa-clock mr-2"></i>
      <%= Time.current.strftime("%H:%M") %>
    </div>
  </div>
</div>