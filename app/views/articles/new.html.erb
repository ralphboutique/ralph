
<%= form_for  @article, url: create_path  do |f| %>

<%if @article.errors.any? %>
    <div id="error_explanation" class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative">
      <strong class="font-bold"><%= pluralize(@article.errors.count, "error") %> impidieron que el articulo se guardara:</strong>
      <ul class="list-disc pl-5 mt-2">
        <% @article.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
 <div class ="container mx-32">
 
	<div class="space-y-12">
        <div class="mt-10 grid grid-cols-1 gap-x-6 gap-y-8 sm:grid-cols-12">
            <div class="sm:col-span-6 ">
                <%= f.label :title,  "NOMBRE DEL ARTICULO" ,class: "block text-sm font-medium leading-6 text-gray-900" %>
                <div class="mt-2">
                    <%= f.text_field :title , class:"block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6" , oninput: "this.value = this.value.toUpperCase()" %>
                </div>
            </div>
            <div class="sm:col-span-3">
                <%= f.label :serial,  "SERIAL" ,class: "block text-sm font-medium leading-6 text-gray-900" %>
                <div class="mt-2">
                    <%= f.text_field :serial , class:"block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6"%>
                </div>
            </div>
            <div class="sm:col-span-3">
                <%= f.label :price,  "PRECIO" ,class: "block text-sm font-medium leading-6 text-gray-900" %>
                <div class="mt-2">
                    <%= f.number_field :price , class:"block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6"%>
                </div>
            </div>
            <div class="sm:col-span-3">
                <%# <label for="country" class="block text-sm font-medium leading-6 text-gray-900">ALMACEN</label> %>
                <div class="">
                        <%= f.label :warehouse_id, "ALMACEN", class: "block text-sm font-medium leading-6 text-gray-900" %>
                    <div class="mt-2">
                        <%= f.select :warehouse_id, @werehouses.collect {|c| [c.title.upcase , c.id]},{  prompt: "Seleccionar Almacen"}, {class: "rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 form-select block w-full p-2 text-base font-medium text-gray-700 bg-white border border-gray-300 rounded-md appearance-none caret-indigo-600 transition duration-150 ease-in-out transform"} %>
                    </div>
                </div>
            </div>
            <div class="sm:col-span-3">
                <%= f.label :category_id,"CATEGORIA", class: "block text-sm font-medium leading-6 text-gray-900" %>
                <div class="mt-2">
                  <%= f.select :category_id, options_for_select(@categories.map { |c| [c.title.upcase, c.id] }), { prompt: "Seleccionar categoría" }, { class: "rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 form-select block w-full p-2 text-base font-medium text-gray-700 bg-white border border-gray-300 rounded-md appearance-none caret-indigo-600 transition duration-150 ease-in-out transform" } %>
                </div>
            </div>
              <div class="sm:col-span-3">
                 <%= f.label :size_id,"TALLA" ,class: "block text-sm font-medium leading-6 text-gray-900" %>
                  <div class="mt-2">
                    <%= f.select :size_ids, @sizes.collect { |c| [c.title.upcase, c.id] }, {}, multiple: true, class: "rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 form-select block w-full p-3.5 text-base font-medium text-gray-700 bg-white border border-gray-300 rounded-md appearance-none caret-indigo-600 transition duration-150 ease-in-out transform" %>
                  </div>
                </div>
                <div class="sm:col-span-3">
                 
              </div>
		</div>

			<div class="mt-1 grid grid-cols-1 gap-x-6 gap-y-8 sm:grid-cols-6">
					<div class="col-span-full">
					<%= f.label :description,"DESCRIPCION DEL PRODUCTO", class: "block text-sm font-medium leading-6 text-gray-900" %>
					<div class="mt-2">
                        <%= f.text_area :description, size: "100x5" %>
                    </div>
					<p class="mt-3 text-sm leading-6 text-gray-600">Escribe las caracteristicas del producto.</p>
					</div>

					<div class="col-span-6">
					<label for="cover-photo" class="block text-sm font-medium leading-6 text-gray-900">Insertar imagen</label>
					<div class="mt-2 flex justify-center rounded-lg border border-dashed border-gray-900/25 px-6 py-10">
							<div class="text-center">
							<svg class="mx-auto h-12 w-12 text-gray-300" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
									<path fill-rule="evenodd" d="M1.5 6a2.25 2.25 0 012.25-2.25h16.5A2.25 2.25 0 0122.5 6v12a2.25 2.25 0 01-2.25 2.25H3.75A2.25 2.25 0 011.5 18V6zM3 16.06V18c0 .414.336.75.75.75h16.5A.75.75 0 0021 18v-1.94l-2.69-2.689a1.5 1.5 0 00-2.12 0l-.88.879.97.97a.75.75 0 11-1.06 1.06l-5.16-5.159a1.5 1.5 0 00-2.12 0L3 16.061zm10.125-7.81a1.125 1.125 0 112.25 0 1.125 1.125 0 01-2.25 0z" clip-rule="evenodd" />
							</svg>
							<div class="mt-4 flex text-sm leading-6 text-gray-600">
                                    <%= f.file_field :attachment %>
									
							</div>
							</div>
					</div>
          <div class="field">    
           </div>
           <div data-controller="color-create" class="mt-6">
            <label>Anadir color</label>
              <div id="color-container" data-color-create-target="container" class="space-y-2 flex flex-wrap"></div>
              <button type="button" class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-1 px-2 mt-2 rounded" data-action="color-create#addColor">
                Añadir Color
              </button>
            </div>
					 <div class="mt-6  mb-14 flex items-center justify-end gap-x-6">
                            <%= link_to "Cancelar", index_path %>
							<%= f.submit "CREAR ARTICULO", class:"rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600" %>
					 </div>
				</div>
		</div>
	<% end %>
</div>

